<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="MDMBrowseFillTypesDialog" onOpen="onOpen" onClose="onClose" onCreate="onCreate">
  <GuiElement profile="newLayer" />
  <Bitmap profile="dialogFullscreenBg" />

  <GuiElement profile="dialogBg" id="dialogElement" size="600px 700px">
    <ThreePartBitmap profile="fs25_dialogBgMiddle" />
    <ThreePartBitmap profile="fs25_dialogBgTop" />
    <ThreePartBitmap profile="fs25_dialogBgBottom" />

    <GuiElement profile="fs25_dialogContentContainer">
      <Text profile="fs25_dialogTitle" id="title" text="$l10n_mdm_browse_title" position="0px -14px" size="520px 28px"/>
      <Bitmap profile="mdmBrowse_sep" position="0px -48px" size="520px 2px"/>

      <Text profile="mdmBrowse_hint" text="$l10n_mdm_browse_hint"
            position="0px -64px" size="520px 40px"/>

      <!-- Search / filter input -->
      <Text profile="mdmBrowse_searchLabel" text="$l10n_mdm_browse_search" position="0px -112px" size="520px 20px"/>
      <TextInput profile="mdmBrowse_searchInput" id="browseSearchInput"
                 position="0px -134px" size="510px 34px"
                 maxCharacters="60"
                 onTextChanged="onSearchChanged"
                 onEnterPressed="onSearchChanged">
        <ThreePartBitmap profile="fs25_textInputBg" absoluteSizeOffset="0px 0px"/>
      </TextInput>

      <!-- Scrollable area — shifted down 58px to accommodate filter row -->
      <Slider profile="fs25_slider" id="listSlider" dataElementId="scrollingLayout" position="510px -174px" size="10px 446px" />
      <ScrollingLayout profile="fs25_settingsLayout" id="scrollingLayout" position="0px -174px" size="510px 446px">
          <!-- Elements added programmatically in Lua -->
      </ScrollingLayout>

    </GuiElement>

    <BoxLayout profile="fs25_dialogButtonBox">
      <Button profile="buttonBack" text="$l10n_button_close" onClick="onCloseClick" id="closeBtn"/>
    </BoxLayout>
  </GuiElement>

  <GUIProfiles>
    <Profile name="mdmBrowse_sep" extends="baseReference" with="anchorTopLeft">
      <imageColor value="1.0 1.0 1.0 0.18"/>
    </Profile>
    <Profile name="mdmBrowse_hint" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="0.65 0.65 0.65 1.0"/>
      <textWrap value="true"/>
    </Profile>
    <Profile name="mdmBrowse_searchLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="11px"/>
      <textBold value="true"/>
      <textColor value="0.50 0.50 0.50 1.0"/>
    </Profile>
    <Profile name="mdmBrowse_searchInput" extends="fs25_textInput" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="1 1 1 1"/>
    </Profile>
    <Profile name="mdmFt_row" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="14px"/>
        <textColor value="1 1 1 1"/>
        <textFocusedColor value="1 0.85 0.1 1"/>
        <size value="500px 32px"/>
        <textAlignment value="left"/>
        <textOffset value="12px 0px"/>
        <imageColor value="0 0 0 0"/>
    </Profile>
  </GUIProfiles>
</GUI>
