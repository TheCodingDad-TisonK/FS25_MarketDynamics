<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    MDM Event Settings Dialog
    MessageDialog subclass — global event settings + per-event on/off + fill type editor access.
    Controller: MDMEventSettingsDialog (src/gui/MDMEventSettingsDialog.lua)

    Layout (Y-down from fs25_dialogContentContainer top):
      Title / Global section (enabled toggle + frequency) / Per-event rows (10 rows)

    Per-event columns: Name | Enabled/Disabled toggle | Custom fills count | Edit button
    All buttons use 3-layer pattern: Bitmap bg + Button hit + Text label.
-->
<GUI name="MDMEventSettingsDialog" onOpen="onOpen" onClose="onClose" onCreate="onCreate">
  <GuiElement profile="newLayer" />
  <Bitmap profile="dialogFullscreenBg" />

  <GuiElement profile="dialogBg" id="dialogElement" size="800px 760px">
    <ThreePartBitmap profile="fs25_dialogBgMiddle" />
    <ThreePartBitmap profile="fs25_dialogBgTop" />
    <ThreePartBitmap profile="fs25_dialogBgBottom" />

    <GuiElement profile="fs25_dialogContentContainer">

      <!-- ═══ TITLE ═══ -->
      <Text profile="mdmEvtS_title" id="evtSDlgTitle" text="Event Settings" position="0px -14px" size="700px 28px"/>
      <Bitmap profile="mdmEvtS_sep" position="0px -48px" size="700px 2px"/>

      <!-- ═══ GLOBAL SECTION ═══ -->
      <Text profile="mdmEvtS_sectionLabel" text="GLOBAL" position="0px -66px" size="200px 22px"/>

      <!-- Events Enabled toggle -->
