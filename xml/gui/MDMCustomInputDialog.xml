<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    MDM Custom Input Dialog
    MessageDialog subclass — number entry for custom quantity or custom delivery days.
    Time unit (game/real days) is now controlled by the toggle in MDMContractDialog.
-->
<GUI name="MDMCustomInputDialog" onOpen="onOpen" onClose="onClose" onCreate="onCreate">
  <GuiElement profile="newLayer" />
  <Bitmap profile="dialogFullscreenBg" />

  <GuiElement profile="dialogBg" id="dialogElement" size="580px 360px">
    <ThreePartBitmap profile="fs25_dialogBgMiddle" />
    <ThreePartBitmap profile="fs25_dialogBgTop" />
    <ThreePartBitmap profile="fs25_dialogBgBottom" />

    <GuiElement profile="fs25_dialogContentContainer">

      <!-- Title -->
      <Text profile="mdmCustom_title" id="dlgTitle" text="Custom Input" position="0px -12px" size="500px 30px"/>

      <Bitmap profile="mdmCustom_separator" position="0px -48px" size="500px 2px"/>

      <!-- Input label -->
      <Text profile="mdmCustom_label" id="dlgInputLabel" text="Enter Value:" position="0px -68px"/>

      <!-- Text input -->
      <TextInput profile="fs25_textInput" id="textInput"
                 position="0px -100px" size="500px 44px"
                 maxCharacters="10"
                 onTextChanged="onTextChanged"
                 onEnterPressed="onConfirmClick">
        <ThreePartBitmap profile="fs25_textInputBg" absoluteSizeOffset="0px 0px"/>
      </TextInput>

      <!-- Hint (context set by Lua based on mode) -->
      <Text profile="mdmCustom_hint" id="dlgHint" position="0px -162px" size="500px 60px"/>

    </GuiElement>

    <BoxLayout profile="fs25_dialogButtonBox">
      <Button profile="buttonBack" text="$l10n_button_cancel"  onClick="onCancelClick"  id="btnCancel"/>
      <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
      <Button profile="buttonOK"   text="$l10n_button_confirm" onClick="onConfirmClick" id="btnConfirm"/>
    </BoxLayout>

  </GuiElement>

  <GUIProfiles>
    <Profile name="mdmCustom_title" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="20px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>
    <Profile name="mdmCustom_separator" extends="baseReference" with="anchorTopLeft">
      <imageColor value="1.0 1.0 1.0 0.18"/>
    </Profile>
    <Profile name="mdmCustom_label" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="13px"/>
      <textBold value="true"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="mdmCustom_hint" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="$preset_colorWhite_50"/>
      <textWrap value="true"/>
    </Profile>
  </GUIProfiles>
</GUI>
