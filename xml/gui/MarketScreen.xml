<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    MDM Market Screen
    InGameMenu page — follows EmployeeManager pattern (no newLayer, no fullScreenBackground).
    Controller: MDMMarketScreen (src/gui/MarketScreen.lua)
-->
<GUI name="menuMarketDynamics">
  <GuiElement profile="fs25_menuContainer">

    <!-- Header bar with icon, title, and money box -->
    <GuiElement profile="fs25_menuHeaderPanel" position="-200px 90px" width="800px">
      <Bitmap profile="fs25_menuHeaderIconBg">
        <Bitmap profile="MDM_IconMenu"/>
      </Bitmap>
      <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText" text="$l10n_mdm_screen_title"/>

      <RoundCorner profile="fs25_shopMoneyBoxBg" id="shopMoneyBoxBg" position="380px 0px" />
      <BoxLayout profile="fs25_shopMoneyBox" id="shopMoneyBox" position="350px 0px">
        <Text profile="fs25_shopBalance" text="$l10n_mdm_screen_balance"/>
        <Text profile="fs25_shopMoney" id="currentBalanceText"/>
      </BoxLayout>
    </GuiElement>

    <!-- Two-column layout container -->
    <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px 0px">

      <!-- LEFT COLUMN: Commodity list -->
      <!-- profile="fs25_primaryMenuContainerBg" -->
      <ThreePartBitmap width="460px" height="700px" position="0px 100px" >
        <!-- <Bitmap profile="fs25_menuContainerArrow"/> -->

        <GuiElement profile="fs25_subCategoryContainer" width="420px">
          <Text profile="mdm_sectionHeader" id="commoditiesHeader" text="$l10n_mdm_screen_commodities" position="10px -10px" />

          <!-- Column headers -->
          <GuiElement profile="mdm_listHeaderRow" position="0px -40px">
            <Text profile="mdm_colHeaderLeft" id="colHeaderCrop" text="$l10n_mdm_screen_col_crop" position="10px 0" />
            <Text profile="mdm_colHeaderLeft" id="colHeaderPrice" text="$l10n_mdm_screen_col_price" position="200px 0" />
            <Text profile="mdm_colHeaderRight" id="colHeaderChange" text="$l10n_mdm_screen_col_change" position="250px 0" />
          </GuiElement>

          <!-- Commodity SmoothList -->
          <GuiElement profile="fs25_subCategoryListContainer" id="commodityListContainer" position="0px -75px" width="420px" height="700px" debugEnabled="false">
            <SmoothList id="commodityList" profile="mdm_smoothList"
                        startClipperElementName="leftStartClipper"
                        endClipperElementName="leftEndClipper">
              <ListItem profile="mdm_commodityItem" onClick="onClickCommodity">
                <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                <Text profile="mdm_cellLeft" name="cropName" />
                <Text profile="mdm_cellLeft" name="cropPrice" position="200px 0"/>
                <Text profile="mdm_cellRight" name="cropChange" />
              </ListItem>
            </SmoothList>

            <Bitmap profile="fs25_secondaryMenuStartClipper" name="leftStartClipper"/>
            <Bitmap profile="fs25_secondaryMenuStopClipper" name="leftEndClipper"/>

            <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
              <Slider profile="fs25_listSlider" dataElementId="commodityList"/>
            </ThreePartBitmap>
          </GuiElement>
        </GuiElement>
      </ThreePartBitmap>

      <!-- RIGHT COLUMN: Price detail + graph -->
      <GuiElement id="rightPanel" position="500px 100px" width="1000px" height="700px">

        <!-- PRICES content (visible by default) -->
        <GuiElement id="pricesContent" position="0px 0px" width="1000px" height="700px" debugEnabled="false">
          <!-- Compact detail: crop name + key stats -->
          <Text profile="mdm_detailCropName" id="detailCropName" position="0px -10px" size="580px 30px"/>
          <Text profile="mdm_detailRowInline" id="detailCurrentPrice" text="" position="0px -45px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailBasePrice" text="" position="200px -45px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailChange" text="" position="400px -45px" size="180px 20px"/>
          <Text profile="mdm_detailRowSmall" id="detailVolatility" text="" position="0px -70px" size="190px 16px"/>
          <Text profile="mdm_detailRowSmall" id="detailModifiers" text="" position="200px -70px" size="190px 16px"/>

          <!-- Price evolution line chart -->
          <Text profile="mdm_sectionHeader" id="graphTitle" text="$l10n_mdm_screen_session_trend" position="0px -100px" size="700px 24px" debugEnabled="false"/>

          <GuiElement id="graphArea" position="0px -100px" width="1000px" height="600px" debugEnabled="false">
            <Text profile="mdm_graphHint" id="graphHint" text="$l10n_mdm_screen_collecting"/>
          </GuiElement>
        </GuiElement>

        <!-- Events content (hidden by default, toggled via tabs) -->
        <GuiElement id="eventsContent" position="0px 0px" width="1000px" height="600px" visible="false" debugEnabled="false">
          <Text profile="mdm_sectionHeader" id="eventsHeader" text="$l10n_mdm_screen_events_hdr" position="0px -10px"/>
          <SmoothList id="eventList" profile="mdm_smoothList" position="0px -50px" width="1000px" height="500px"
                      startClipperElementName="evStartClipper"
                      endClipperElementName="evEndClipper">
            <ListItem profile="mdm_commodityItem">
              <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
              <Text profile="mdm_cellLeft" name="eventName"/>
              <Text profile="mdm_cellLeft" name="eventIntensity"/>
              <Text profile="mdm_cellRight" name="eventTimeLeft"/>
            </ListItem>
          </SmoothList>
          <Bitmap profile="fs25_secondaryMenuStartClipper" name="evStartClipper"/>
          <Bitmap profile="fs25_secondaryMenuStopClipper" name="evEndClipper"/>
          <Text profile="mdm_emptyHint" id="noEventsText" text="$l10n_mdm_screen_no_events"/>
        </GuiElement>

        <!-- Contracts content (hidden by default) -->
        <GuiElement id="contractsContent" position="0px 0px" width="1000px" height="600px" visible="false" debugEnabled="false">
          <Text profile="mdm_sectionHeader" id="contractsHeader" text="$l10n_mdm_screen_contracts_hdr" position="0px -10px"/>
          <GuiElement profile="mdm_listHeaderRow" position="0px -40px">
            <Text profile="mdm_colHeaderLeft" id="contractsColCrop" text="$l10n_mdm_screen_col_crop" position="10px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColQty" text="Qty" position="140px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColLocked" text="Locked" position="240px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDelivered" text="Delivered" position="330px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDeadline" text="Deadline" position="430px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColStatus" text="Status" position="530px 0"/>
          </GuiElement>
          <SmoothList id="contractList" profile="mdm_smoothList" position="0px -75px" width="1000px" height="450px"
                      startClipperElementName="ctStartClipper"
                      endClipperElementName="ctEndClipper">
            <ListItem profile="mdm_commodityItem">
              <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
              <Text profile="mdm_cellLeft" name="contractCrop"/>
              <Text profile="mdm_cellRight" name="contractQty"/>
              <Text profile="mdm_cellRight" name="contractPrice"/>
              <Text profile="mdm_cellRight" name="contractProgress"/>
              <Text profile="mdm_cellRight" name="contractDeadline"/>
              <Text profile="mdm_cellRight" name="contractStatus"/>
            </ListItem>
          </SmoothList>
          <Bitmap profile="fs25_secondaryMenuStartClipper" name="ctStartClipper"/>
          <Bitmap profile="fs25_secondaryMenuStopClipper" name="ctEndClipper"/>
          <Text profile="mdm_emptyHint" id="noContractsText" text="$l10n_mdm_screen_no_contracts"/>
          <Text profile="mdm_hintText" id="newContractHint" text="$l10n_mdm_screen_new_contract"/>
        </GuiElement>
      </GuiElement>

    </GuiElement>
  </GuiElement>

  <!-- Inline profiles -->
  <GUIProfiles>
    <!-- Menu icon for header -->
    <Profile name="MDM_IconMenu" extends="baseReference" with="anchorMiddleCenter">
      <size value="50px 50px"/>
      <imageSliceId value="noSlice"/>
      <imageFilename value="g_MDMIconMenu"/>
      <imageColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <!-- Section header -->
    <Profile name="mdm_sectionHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="18px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- List header row -->
    <Profile name="mdm_listHeaderRow" extends="emptyPanel" with="anchorTopStretchingX">
      <height value="32px"/>
    </Profile>

    <!-- Column headers -->
    <Profile name="mdm_colHeaderLeft" extends="fs25_textDefault">
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
      <size value="170px 32px"/>
    </Profile>
    <Profile name="mdm_colHeaderRight" extends="mdm_colHeaderLeft">
      <textAlignment value="right"/>
    </Profile>

    <!-- SmoothList base -->
    <Profile name="mdm_smoothList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
    </Profile>

    <!-- Commodity item row -->
    <Profile name="mdm_commodityItem" extends="emptyPanel" with="anchorTopStretchingX pivotTopLeft">
      <height value="32px"/>
    </Profile>
    <Profile name="mdm_commodityItemBg" extends="baseReference" with="anchorStretchingYStretchingX">
      <imageColor value="$preset_fs25_colorGrey"/>
      <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
      <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
    </Profile>

    <!-- Cell text styles -->
    <Profile name="mdm_cellLeft" extends="fs25_textDefault" with="anchorStretchingYLeft">
      <size value="350px 32px"/>
      <position value="10px 0"/>
      <textSize value="15px"/>
      <textAlignment value="left"/>
      <textColor value="$preset_fs25_colorMainLight"/>
      <textSelectedColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <Profile name="mdm_cellRight" extends="mdm_cellLeft">
      <size value="100px 32px"/>
      <position value="290px 0"/>
      <textAlignment value="right"/>
    </Profile>

    <!-- Detail card -->
    <Profile name="mdm_detailCropName" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="24px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>
    <Profile name="mdm_detailRow" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="16px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowInline" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowSmall" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- Hints -->
    <Profile name="mdm_graphHint" extends="fs25_textDefault" with="anchorMiddleCenter">
      <textSize value="14px"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="mdm_emptyHint" extends="mdm_graphHint"/>
    <Profile name="mdm_hintText" extends="fs25_textDefault" with="anchorBottomRight">
      <textSize value="14px"/>
      <textAlignment value="right"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
  </GUIProfiles>
</GUI>
