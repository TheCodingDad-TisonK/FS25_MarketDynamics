<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    MDM Market Screen
    InGameMenu page — follows EmployeeManager pattern (no newLayer, no fullScreenBackground).
    Controller: MDMMarketScreen (src/gui/MarketScreen.lua)
-->
<GUI name="menuMarketDynamics">
  <GuiElement profile="fs25_menuContainer">

    <!-- Header bar with icon, title, and money box -->
    <GuiElement profile="fs25_menuHeaderPanel" position="-200px 90px" width="800px">
      <Bitmap profile="fs25_menuHeaderIconBg">
        <Bitmap profile="MDM_IconMenu"/>
      </Bitmap>
      <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText" text="$l10n_mdm_screen_title"/>

      <RoundCorner profile="fs25_shopMoneyBoxBg" id="shopMoneyBoxBg" position="380px 0px" />
      <BoxLayout profile="fs25_shopMoneyBox" id="shopMoneyBox" position="350px 0px">
        <Text profile="fs25_shopBalance" text="$l10n_mdm_screen_balance"/>
        <Text profile="fs25_shopMoney" id="currentBalanceText"/>
      </BoxLayout>
    </GuiElement>

    <!-- Two-column layout container -->
    <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px 0px">

      <!-- LEFT COLUMN: Commodity list -->
      <!-- profile="fs25_primaryMenuContainerBg" -->
      <ThreePartBitmap width="460px" height="700px" position="0px 100px" >
        <!-- <Bitmap profile="fs25_menuContainerArrow"/> -->

        <GuiElement profile="fs25_subCategoryContainer" width="420px">
          <Text profile="mdm_sectionHeader" id="commoditiesHeader" text="$l10n_mdm_screen_commodities" position="10px -10px" />

          <!-- Column headers -->
          <GuiElement profile="mdm_listHeaderRow" position="0px -40px">
            <Text profile="mdm_colHeaderLeft" id="colHeaderCrop" text="$l10n_mdm_screen_col_crop" position="10px 0" />
            <Text profile="mdm_colHeaderLeft" id="colHeaderPrice" text="$l10n_mdm_screen_col_price" position="200px 0" />
            <Text profile="mdm_colHeaderRight" id="colHeaderChange" text="$l10n_mdm_screen_col_change" position="250px 0" />
          </GuiElement>

          <!-- Commodity SmoothList -->
          <GuiElement profile="fs25_subCategoryListContainer" id="commodityListContainer" position="0px -75px" width="420px" height="700px" debugEnabled="false">
            <SmoothList id="commodityList" profile="mdm_smoothList"
                        startClipperElementName="leftStartClipper"
                        endClipperElementName="leftEndClipper">
              <ListItem profile="mdm_commodityItem" onClick="onClickCommodity">
                <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                <Text profile="mdm_cellLeft" name="cropName" />
                <Text profile="mdm_cellLeft" name="cropPrice" position="200px 0"/>
                <Text profile="mdm_cellRight" name="cropChange" />
              </ListItem>
            </SmoothList>

            <Bitmap profile="fs25_secondaryMenuStartClipper" name="leftStartClipper"/>
            <Bitmap profile="fs25_secondaryMenuStopClipper" name="leftEndClipper"/>

            <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
              <Slider profile="fs25_listSlider" dataElementId="commodityList"/>
            </ThreePartBitmap>
          </GuiElement>
        </GuiElement>
      </ThreePartBitmap>

      <!-- RIGHT COLUMN: Price detail + graph -->
      <GuiElement id="rightPanel" position="500px 100px" width="1000px" height="760px">

        <!-- Tab bar -->
        <GuiElement id="tabBar" position="0px 0px" width="1000px" height="50px">
          <Button profile="mdm_tabButton" id="tabButtonPrices"    onClick="onClickTabPrices"    text="$l10n_mdm_screen_tab_prices"    position="0px 0px"/>
          <Button profile="mdm_tabButton" id="tabButtonEvents"    onClick="onClickTabEvents"    text="$l10n_mdm_screen_tab_events"    position="200px 0px"/>
          <Button profile="mdm_tabButton" id="tabButtonContracts" onClick="onClickTabContracts" text="$l10n_mdm_screen_tab_contracts" position="400px 0px"/>
        </GuiElement>

        <!-- PRICES content (visible by default) -->
        <GuiElement id="pricesContent" position="0px -55px" width="1000px" height="700px" debugEnabled="false">
          <!-- Compact detail: crop name + key stats -->
          <Text profile="mdm_detailCropName" id="detailCropName" position="0px -10px" size="580px 30px"/>
          <Text profile="mdm_detailRowInline" id="detailCurrentPrice" text="" position="0px -45px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailBasePrice" text="" position="200px -45px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailChange" text="" position="400px -45px" size="180px 20px"/>
          <Text profile="mdm_detailRowSmall" id="detailVolatility" text="" position="0px -70px" size="190px 16px"/>
          <Text profile="mdm_detailRowSmall" id="detailModifiers" text="" position="200px -70px" size="190px 16px"/>

          <!-- Price evolution line chart -->
          <Text profile="mdm_sectionHeader" id="graphTitle" text="$l10n_mdm_screen_session_trend" position="0px -100px" size="700px 24px" debugEnabled="false"/>

          <GuiElement id="graphArea" position="0px -100px" width="1000px" height="600px" debugEnabled="false">
            <Text profile="mdm_graphHint" id="graphHint" text="$l10n_mdm_screen_collecting"/>
          </GuiElement>
        </GuiElement>

        <!-- Events content (hidden by default, toggled via tabs) -->
        <GuiElement id="eventsContent" position="0px -55px" width="1000px" height="600px" visible="false" debugEnabled="false">
          <Text profile="mdm_sectionHeader" id="eventsHeader" text="$l10n_mdm_screen_events_hdr" position="0px -10px"/>
          <SmoothList id="eventList" profile="mdm_smoothList" position="0px -50px" width="1000px" height="500px"
                      startClipperElementName="evStartClipper"
                      endClipperElementName="evEndClipper">
            <ListItem profile="mdm_commodityItem">
              <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
              <Text profile="mdm_cellLeft" name="eventName"/>
              <Text profile="mdm_cellLeft" name="eventIntensity"/>
              <Text profile="mdm_cellRight" name="eventTimeLeft"/>
            </ListItem>
          </SmoothList>
          <Bitmap profile="fs25_secondaryMenuStartClipper" name="evStartClipper"/>
          <Bitmap profile="fs25_secondaryMenuStopClipper" name="evEndClipper"/>
          <Text profile="mdm_emptyHint" id="noEventsText" text="$l10n_mdm_screen_no_events"/>
        </GuiElement>

        <!-- Contracts content (hidden by default) -->
        <GuiElement id="contractsContent" position="0px -55px" width="1000px" height="600px" visible="false" debugEnabled="false">
          <Text profile="mdm_sectionHeader" id="contractsHeader" text="$l10n_mdm_screen_contracts_hdr" position="0px -10px"/>
          <GuiElement profile="mdm_listHeaderRow" position="0px -40px">
            <Text profile="mdm_colHeaderLeft" id="contractsColCrop"      text="$l10n_mdm_screen_col_crop"      position="10px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColQty"      text="$l10n_mdm_screen_col_qty"       position="140px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColLocked"   text="$l10n_mdm_screen_col_locked"    position="240px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDelivered" text="$l10n_mdm_screen_col_delivered" position="330px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDeadline" text="$l10n_mdm_screen_col_deadline"  position="430px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColStatus"   text="$l10n_mdm_screen_col_status"    position="530px 0"/>
          </GuiElement>
          <SmoothList id="contractList" profile="mdm_smoothList" position="0px -75px" width="1000px" height="450px"
                      startClipperElementName="ctStartClipper"
                      endClipperElementName="ctEndClipper">
            <ListItem profile="mdm_commodityItem">
              <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
              <Text profile="mdm_cellLeft" name="contractCrop"/>
              <Text profile="mdm_cellRight" name="contractQty"/>
              <Text profile="mdm_cellRight" name="contractPrice"/>
              <Text profile="mdm_cellRight" name="contractProgress"/>
              <Text profile="mdm_cellRight" name="contractDeadline"/>
              <Text profile="mdm_cellRight" name="contractStatus"/>
            </ListItem>
          </SmoothList>
          <Bitmap profile="fs25_secondaryMenuStartClipper" name="ctStartClipper"/>
          <Bitmap profile="fs25_secondaryMenuStopClipper" name="ctEndClipper"/>
          <Text profile="mdm_emptyHint" id="noContractsText" text="$l10n_mdm_screen_no_contracts"/>
          <Button profile="mdm_newContractBtn" id="newContractHint" onClick="onNewContractClick" text="$l10n_mdm_screen_new_contract_btn" position="700px -550px"/>
        </GuiElement>

        <!-- ═══════════════════════════════════════════════════════════════════
             Contract creation dialog overlay (hidden until N / button click)
             ═══════════════════════════════════════════════════════════════════ -->
        <GuiElement id="contractDialog" position="0px 0px" width="1000px" height="760px" visible="false">

          <!-- Dark backdrop -->
          <Bitmap profile="mdm_dialogOverlay" position="0px 0px" width="1000px" height="760px"/>

          <!-- ── Dialog panel ── -->
          <GuiElement position="20px -55px" width="960px" height="660px">

            <!-- Title -->
            <Text profile="mdm_dialogTitle" id="dialogTitleText" text="$l10n_mdm_futures_new_title" position="0px -12px"/>

            <!-- ──────────── LEFT column: crop list ──────────── -->
            <Text profile="mdm_dialogLabel" text="$l10n_mdm_futures_crop_label" position="0px -55px"/>
            <GuiElement position="0px -80px" width="420px" height="380px">
              <SmoothList id="dialogCropList" profile="mdm_smoothList"
                          startClipperElementName="dlgClipStart"
                          endClipperElementName="dlgClipEnd">
                <ListItem profile="mdm_commodityItem" onClick="onDialogCropClick">
                  <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                  <Text profile="mdm_dlgCropName"  name="dlgName"/>
                  <Text profile="mdm_dlgCropPrice" name="dlgPrice"/>
                  <Text profile="mdm_dlgCropChg"   name="dlgChg"/>
                </ListItem>
              </SmoothList>
              <Bitmap profile="fs25_secondaryMenuStartClipper" name="dlgClipStart"/>
              <Bitmap profile="fs25_secondaryMenuStopClipper"  name="dlgClipEnd"/>
            </GuiElement>
            <Text profile="mdm_emptyHint" id="dialogNoCropsText" text="$l10n_mdm_dialog_no_crops" position="0px -260px"/>

            <!-- ──────────── RIGHT column ──────────── -->

            <!-- Quantity presets -->
            <Text profile="mdm_dialogLabel" text="$l10n_mdm_dialog_qty_label" position="455px -55px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn500"   text="500 L"    onClick="onDialogQtyClick" position="455px -82px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn1000"  text="1,000 L"  onClick="onDialogQtyClick" position="613px -82px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn5000"  text="5,000 L"  onClick="onDialogQtyClick" position="771px -82px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn10000" text="10,000 L" onClick="onDialogQtyClick" position="455px -128px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn25000" text="25,000 L" onClick="onDialogQtyClick" position="613px -128px"/>
            <Button profile="mdm_dialogOptBtn" id="qtyBtn50000" text="50,000 L" onClick="onDialogQtyClick" position="771px -128px"/>

            <!-- Delivery window -->
            <Text profile="mdm_dialogLabel" text="$l10n_mdm_dialog_delivery_label" position="455px -180px"/>
            <Button profile="mdm_dialogOptBtn" id="delBtn30"  text="30 Days"  onClick="onDialogDeliveryClick" position="455px -207px"/>
            <Button profile="mdm_dialogOptBtn" id="delBtn60"  text="60 Days"  onClick="onDialogDeliveryClick" position="613px -207px"/>
            <Button profile="mdm_dialogOptBtn" id="delBtn90"  text="90 Days"  onClick="onDialogDeliveryClick" position="455px -253px"/>
            <Button profile="mdm_dialogOptBtn" id="delBtn120" text="120 Days" onClick="onDialogDeliveryClick" position="613px -253px"/>

            <!-- Summary box -->
            <Text profile="mdm_dialogSummaryHdr" text="$l10n_mdm_dialog_summary" position="455px -316px"/>
            <Text profile="mdm_dialogSummaryRow" id="sumCrop"     position="455px -345px"/>
            <Text profile="mdm_dialogSummaryRow" id="sumQty"      position="455px -368px"/>
            <Text profile="mdm_dialogSummaryRow" id="sumLocked"   position="455px -391px"/>
            <Text profile="mdm_dialogSummaryBig" id="sumTotal"    position="455px -420px"/>
            <Text profile="mdm_dialogSummaryRow" id="sumDeadline" position="455px -455px"/>
            <Text profile="mdm_dialogSummarySmall" id="sumPenalty" position="455px -480px"/>

            <!-- Price signal -->
            <Text profile="mdm_dialogSignal" id="dialogSignal" position="455px -520px"/>

            <!-- BC-mode blocked message -->
            <Text profile="mdm_dialogBcBlocked" id="dialogBcBlocked" text="$l10n_mdm_dialog_bc_blocked" position="455px -520px" visible="false"/>

            <!-- Action buttons -->
            <Button profile="mdm_dialogCancelBtn"  id="dialogCancelBtn"  text="$l10n_mdm_futures_cancel"  onClick="onDialogCancel"  position="455px -610px"/>
            <Button profile="mdm_dialogConfirmBtn" id="dialogConfirmBtn" text="$l10n_mdm_futures_confirm" onClick="onDialogConfirm" position="710px -610px"/>

          </GuiElement>
        </GuiElement>

      </GuiElement>
    </GuiElement>
  </GuiElement>

  <!-- Inline profiles -->
  <GUIProfiles>
    <!-- Menu icon for header -->
    <Profile name="MDM_IconMenu" extends="baseReference" with="anchorMiddleCenter">
      <size value="50px 50px"/>
      <imageSliceId value="noSlice"/>
      <imageFilename value="g_MDMIconMenu"/>
      <imageColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <!-- Section header -->
    <Profile name="mdm_sectionHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="18px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- List header row -->
    <Profile name="mdm_listHeaderRow" extends="emptyPanel" with="anchorTopStretchingX">
      <height value="32px"/>
    </Profile>

    <!-- Column headers -->
    <Profile name="mdm_colHeaderLeft" extends="fs25_textDefault">
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
      <size value="170px 32px"/>
    </Profile>
    <Profile name="mdm_colHeaderRight" extends="mdm_colHeaderLeft">
      <textAlignment value="right"/>
    </Profile>

    <!-- SmoothList base -->
    <Profile name="mdm_smoothList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
    </Profile>

    <!-- Commodity item row -->
    <Profile name="mdm_commodityItem" extends="emptyPanel" with="anchorTopStretchingX pivotTopLeft">
      <height value="32px"/>
    </Profile>
    <Profile name="mdm_commodityItemBg" extends="baseReference" with="anchorStretchingYStretchingX">
      <imageColor value="$preset_fs25_colorGrey"/>
      <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
      <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
    </Profile>

    <!-- Cell text styles -->
    <Profile name="mdm_cellLeft" extends="fs25_textDefault" with="anchorStretchingYLeft">
      <size value="350px 32px"/>
      <position value="10px 0"/>
      <textSize value="15px"/>
      <textAlignment value="left"/>
      <textColor value="$preset_fs25_colorMainLight"/>
      <textSelectedColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <Profile name="mdm_cellRight" extends="mdm_cellLeft">
      <size value="100px 32px"/>
      <position value="290px 0"/>
      <textAlignment value="right"/>
    </Profile>

    <!-- Detail card -->
    <Profile name="mdm_detailCropName" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="24px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>
    <Profile name="mdm_detailRow" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="16px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowInline" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowSmall" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- New Contract button (bottom of contracts tab) -->
    <Profile name="mdm_newContractBtn" extends="fs25_buttonText" with="anchorBottomRight">
      <size value="230px 40px"/>
      <textSize value="14px"/>
      <textBold value="true"/>
      <textAlignment value="center"/>
    </Profile>

    <!-- ── Contract dialog profiles ── -->

    <!-- Semi-transparent dark backdrop -->
    <Profile name="mdm_dialogOverlay" extends="baseReference" with="anchorTopLeft">
      <imageColor value="0.04 0.06 0.08 0.88"/>
    </Profile>

    <!-- Dialog title -->
    <Profile name="mdm_dialogTitle" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="22px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- Section label above input groups -->
    <Profile name="mdm_dialogLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- Option button (qty / delivery presets) -->
    <Profile name="mdm_dialogOptBtn" extends="fs25_buttonText" with="anchorTopLeft">
      <size value="148px 38px"/>
      <textSize value="13px"/>
      <textAlignment value="center"/>
    </Profile>

    <!-- Crop list items inside the dialog -->
    <Profile name="mdm_dlgCropName" extends="fs25_textDefault" with="anchorStretchingYLeft">
      <size value="210px 32px"/>
      <position value="10px 0"/>
      <textSize value="14px"/>
      <textAlignment value="left"/>
      <textColor value="$preset_fs25_colorMainLight"/>
      <textSelectedColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <Profile name="mdm_dlgCropPrice" extends="mdm_dlgCropName">
      <size value="100px 32px"/>
      <position value="230px 0"/>
      <textAlignment value="right"/>
    </Profile>
    <Profile name="mdm_dlgCropChg" extends="mdm_dlgCropName">
      <size value="80px 32px"/>
      <position value="335px 0"/>
      <textAlignment value="right"/>
    </Profile>

    <!-- Summary section header -->
    <Profile name="mdm_dialogSummaryHdr" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="13px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- Summary body rows -->
    <Profile name="mdm_dialogSummaryRow" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>

    <!-- Total value — bigger + highlighted -->
    <Profile name="mdm_dialogSummaryBig" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="20px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- Penalty note (small, muted) -->
    <Profile name="mdm_dialogSummarySmall" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- Price signal (color set dynamically by Lua) -->
    <Profile name="mdm_dialogSignal" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textBold value="true"/>
    </Profile>

    <!-- BC mode blocked message -->
    <Profile name="mdm_dialogBcBlocked" extends="fs25_textDefault" with="anchorMiddleCenter">
      <textSize value="16px"/>
      <textBold value="true"/>
      <textAlignment value="center"/>
      <textColor value="0.95 0.75 0.10 1.0"/>
    </Profile>

    <!-- Cancel button -->
    <Profile name="mdm_dialogCancelBtn" extends="fs25_buttonText" with="anchorTopLeft">
      <size value="240px 44px"/>
      <textSize value="15px"/>
      <textAlignment value="center"/>
    </Profile>

    <!-- Confirm button (same size but bold) -->
    <Profile name="mdm_dialogConfirmBtn" extends="fs25_buttonText" with="anchorTopLeft">
      <size value="240px 44px"/>
      <textSize value="15px"/>
      <textBold value="true"/>
      <textAlignment value="center"/>
    </Profile>

    <!-- Tab button -->
    <Profile name="mdm_tabButton" extends="fs25_buttonText" with="anchorTopLeft">
      <size value="180px 40px"/>
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textAlignment value="center"/>
    </Profile>

    <!-- Hints -->
    <Profile name="mdm_graphHint" extends="fs25_textDefault" with="anchorMiddleCenter">
      <textSize value="14px"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="mdm_emptyHint" extends="mdm_graphHint"/>
    <Profile name="mdm_hintText" extends="fs25_textDefault" with="anchorBottomRight">
      <textSize value="14px"/>
      <textAlignment value="right"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
  </GUIProfiles>
</GUI>
