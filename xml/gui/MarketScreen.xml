<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    MDM Market Screen
    InGameMenu page — follows EmployeeManager pattern (no newLayer, no fullScreenBackground).
    Controller: MDMMarketScreen (src/gui/MarketScreen.lua)
-->
<GUI name="menuMarketDynamics">
  <GuiElement profile="fs25_menuContainer">

    <!-- Header bar with icon, title, and money box -->
    <GuiElement profile="fs25_menuHeaderPanel" position="-200px 90px" width="800px">
      <Bitmap profile="fs25_menuHeaderIconBg">
        <Bitmap profile="MDM_IconMenu"/>
      </Bitmap>
      <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText" text="$l10n_mdm_screen_title"/>

      <RoundCorner profile="fs25_shopMoneyBoxBg" id="shopMoneyBoxBg" position="380px 0px" />
      <BoxLayout profile="fs25_shopMoneyBox" id="shopMoneyBox" position="350px 0px">
        <Text profile="fs25_shopBalance" text="$l10n_mdm_screen_balance"/>
        <Text profile="fs25_shopMoney" id="currentBalanceText"/>
      </BoxLayout>
    </GuiElement>

    <!-- Two-column layout container -->
    <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="0px 0px">

      <!-- LEFT COLUMN: Commodity list -->
      <!-- profile="fs25_primaryMenuContainerBg" -->
      <ThreePartBitmap width="460px" height="700px" position="0px 100px" >
        <!-- <Bitmap profile="fs25_menuContainerArrow"/> -->

        <GuiElement profile="fs25_subCategoryContainer" width="420px">
          <Text profile="mdm_sectionHeader" id="commoditiesHeader" text="$l10n_mdm_screen_commodities" position="10px -10px" />

          <!-- Column headers -->
          <GuiElement profile="mdm_listHeaderRow" position="0px -40px">
            <Text profile="mdm_colHeaderLeft" id="colHeaderCrop" text="$l10n_mdm_screen_col_crop" position="10px 0" />
            <Text profile="mdm_colHeaderLeft" id="colHeaderPrice" text="$l10n_mdm_screen_col_price" position="200px 0" />
            <Text profile="mdm_colHeaderRight" id="colHeaderChange" text="$l10n_mdm_screen_col_change" position="250px 0" />
          </GuiElement>

          <!-- Commodity SmoothList -->
          <GuiElement profile="fs25_subCategoryListContainer" id="commodityListContainer" position="0px -75px" width="420px" height="700px" debugEnabled="false">
            <SmoothList id="commodityList" profile="mdm_smoothList"
                        startClipperElementName="leftStartClipper"
                        endClipperElementName="leftEndClipper">
              <ListItem profile="mdm_commodityItem" onClick="onClickCommodity">
                <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                <Bitmap profile="mdm_cropIcon" name="cropIcon"/>
                <Text profile="mdm_cellLeft" name="cropName" position="38px 0"/>
                <Text profile="mdm_cellLeft" name="cropPrice" position="200px 0"/>
                <Text profile="mdm_cellRight" name="cropChange" />
              </ListItem>
            </SmoothList>

            <Bitmap profile="fs25_secondaryMenuStartClipper" name="leftStartClipper"/>
            <Bitmap profile="fs25_secondaryMenuStopClipper" name="leftEndClipper"/>

            <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
              <Slider profile="fs25_listSlider" dataElementId="commodityList"/>
            </ThreePartBitmap>
          </GuiElement>
        </GuiElement>
      </ThreePartBitmap>

      <!-- RIGHT COLUMN: Price detail + graph -->
      <GuiElement id="rightPanel" position="500px 100px" width="1000px" height="700px">

        <!-- PRICES content (visible by default)
             Y-UP: position 0px 0px fills rightPanel from bottom (Y=0) to Y=668.
             Children use anchorTopLeft: Y_position = 668 - intendedPixelsFromTop -->
        <GuiElement id="pricesContent" position="0px 0px" width="1000px" height="668px" debugEnabled="false">
          <!-- Crop name: 10px from top → TOP at 658 -->
          <Text profile="mdm_detailCropName" id="detailCropName" position="0px 658px" size="580px 30px"/>
          <!-- Price row: 45px from top → TOP at 623 -->
          <Text profile="mdm_detailRowInline" id="detailCurrentPrice" text="" position="0px 623px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailBasePrice"    text="" position="200px 623px" size="190px 20px"/>
          <Text profile="mdm_detailRowInline" id="detailChange"       text="" position="400px 623px" size="180px 20px"/>
          <!-- Small stats row: 70px from top → TOP at 598 -->
          <Text profile="mdm_detailRowSmall" id="detailVolatility" text="" position="0px 598px" size="190px 16px"/>
          <Text profile="mdm_detailRowSmall" id="detailModifiers"  text="" position="200px 598px" size="190px 16px"/>
          <!-- Graph title: 108px from top → TOP at 560 -->
          <Text profile="mdm_sectionHeader" id="graphTitle" text="$l10n_mdm_screen_session_trend" position="0px 560px" size="700px 24px" debugEnabled="false"/>
          <!-- Graph area: fills bottom 530px (Y=0–530), below the title row -->
          <GuiElement id="graphArea" position="0px 0px" width="1000px" height="530px" debugEnabled="false">
            <Text profile="mdm_graphHint" id="graphHint" text="$l10n_mdm_screen_collecting"/>
          </GuiElement>
        </GuiElement>

        <!-- Events content (hidden by default, toggled via tabs) -->
        <GuiElement id="eventsContent" position="0px 0px" width="1000px" height="668px" visible="false" debugEnabled="false">
          <!-- Header: 10px from top → TOP at 658 -->
          <Text profile="mdm_sectionHeader" id="eventsHeader" text="$l10n_mdm_screen_events_hdr" position="0px 658px"/>
          <!-- Column headers: 40px from top → TOP at 628 -->
          <GuiElement profile="mdm_listHeaderRow" position="0px 628px">
            <Text profile="mdm_colHeaderLeft"  text="$l10n_mdm_screen_col_event"     position="10px 0"/>
            <Text profile="mdm_colHeaderRight" text="$l10n_mdm_screen_col_intensity" position="500px 0"/>
            <Text profile="mdm_colHeaderRight" text="$l10n_mdm_screen_col_time_left" position="700px 0"/>
          </GuiElement>
          <!-- List container: Y-UP anchorBottomLeft. bottom=118, height=475 → top=593 (75px from content top) -->
          <GuiElement id="eventListContainer" position="0px 118px" width="1000px" height="475px">
            <SmoothList id="eventList" profile="mdm_smoothList">
              <ListItem profile="mdm_commodityItem">
                <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                <Text profile="mdm_cellLeft" name="eventName"/>
                <Text profile="mdm_cellLeft" name="eventIntensity" position="350px 0px"/>
                <Text profile="mdm_cellRight" name="eventTimeLeft" position="700px 0px"/>
              </ListItem>
            </SmoothList>
          </GuiElement>
          <Text profile="mdm_emptyHint" id="noEventsText" text="$l10n_mdm_screen_no_events"/>
        </GuiElement>

        <!-- Contracts content (hidden by default) -->
        <GuiElement id="contractsContent" position="0px 0px" width="1000px" height="668px" visible="false" debugEnabled="false">
          <!-- Header: 10px from top → TOP at 658 -->
          <Text profile="mdm_sectionHeader" id="contractsHeader" text="$l10n_mdm_screen_contracts_hdr" position="0px 658px"/>
          <!-- Column headers: 40px from top → TOP at 628 -->
          <GuiElement profile="mdm_listHeaderRow" position="0px 628px">
            <Text profile="mdm_colHeaderLeft" id="contractsColCrop"       text="$l10n_mdm_screen_col_crop"       position="10px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColQty"       text="$l10n_mdm_screen_col_qty"        position="140px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColLocked"    text="$l10n_mdm_screen_col_locked"     position="240px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDelivered" text="$l10n_mdm_screen_col_delivered"  position="330px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColDeadline"  text="$l10n_mdm_screen_col_deadline"   position="430px 0"/>
            <Text profile="mdm_colHeaderRight" id="contractsColStatus"    text="$l10n_mdm_screen_col_status"     position="530px 0"/>
          </GuiElement>
          <!-- List container: Y-UP anchorBottomLeft. bottom=143, height=450 → top=593 (75px from content top) -->
          <GuiElement id="contractListContainer" position="0px 143px" width="1000px" height="450px">
            <SmoothList id="contractList" profile="mdm_smoothList">
              <ListItem profile="mdm_commodityItem">
                <Bitmap profile="mdm_commodityItemBg" name="alternating"/>
                <Text profile="mdm_cellLeft"  name="contractCrop"     size="130px 32px"/>
                <Text profile="mdm_cellRight" name="contractQty"      position="140px 0px"/>
                <Text profile="mdm_cellRight" name="contractPrice"    position="240px 0px"/>
                <Text profile="mdm_cellRight" name="contractProgress" position="330px 0px"/>
                <Text profile="mdm_cellRight" name="contractDeadline" position="430px 0px"/>
                <Text profile="mdm_cellRight" name="contractStatus"   position="530px 0px" size="200px 32px"/>
              </ListItem>
            </SmoothList>
          </GuiElement>
          <Text profile="mdm_emptyHint" id="noContractsText" text="$l10n_mdm_screen_no_contracts"/>
          <Text profile="mdm_hintText" id="newContractHint" position="0px 30px"/>
        </GuiElement>

        <!-- tabBar LAST: FS25 processes mouse events in reverse XML order.
             Declared after all content panels so it gets click priority. -->
        <GuiElement id="tabBar" profile="emptyPanel" position="0px 668px" width="1000px" height="30px">
          <Button profile="mdm_tabBtnHit" onClick="onClickTabPrices"    position="0px 0px"   size="160px 28px"/>
          <Text   profile="mdm_tabLabel"  id="tabLabelPrices"    text="$l10n_mdm_screen_tab_prices"    onClick="onClickTabPrices"    position="0px 28px"   size="160px 28px"/>
          <Bitmap profile="mdm_tabUnderline" id="tabUnderlinePrices"    position="0px 0px"   size="160px 2px"/>
          <Button profile="mdm_tabBtnHit" onClick="onClickTabEvents"    position="170px 0px" size="160px 28px"/>
          <Text   profile="mdm_tabLabel"  id="tabLabelEvents"    text="$l10n_mdm_screen_tab_events"    onClick="onClickTabEvents"    position="170px 28px" size="160px 28px"/>
          <Bitmap profile="mdm_tabUnderline" id="tabUnderlineEvents"    position="170px 0px" size="160px 2px" visible="false"/>
          <Button profile="mdm_tabBtnHit" onClick="onClickTabContracts" position="340px 0px" size="200px 28px"/>
          <Text   profile="mdm_tabLabel"  id="tabLabelContracts" text="$l10n_mdm_screen_tab_contracts" onClick="onClickTabContracts" position="340px 28px" size="200px 28px"/>
          <Bitmap profile="mdm_tabUnderline" id="tabUnderlineContracts" position="340px 0px" size="200px 2px" visible="false"/>
        </GuiElement>
        <Bitmap profile="mdm_tabDivider" position="0px 666px" size="1000px 2px"/>

      </GuiElement>
    </GuiElement>
  </GuiElement>

  <!-- Inline profiles -->
  <GUIProfiles>
    <!-- Menu icon for header -->
    <Profile name="MDM_IconMenu" extends="baseReference" with="anchorMiddleCenter">
      <size value="50px 50px"/>
      <imageSliceId value="noSlice"/>
      <imageFilename value="g_MDMIconMenu"/>
      <imageColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <!-- Invisible hit area for tab clicks — UsedPlus fmfRowHit pattern -->
    <Profile name="mdm_tabBtnHit" extends="emptyPanel">
      <isFocusable value="true"/>
    </Profile>
    <!-- Visual tab label — isFocusable so it receives mouse clicks as a fallback hit target -->
    <Profile name="mdm_tabLabel" extends="fs25_textDefault" with="anchorTopLeft">
      <isFocusable value="true"/>
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <!-- Thin divider line below tab bar -->
    <Profile name="mdm_tabDivider" extends="baseReference" with="anchorTopLeft">
      <imageColor value="1.0 1.0 1.0 0.12"/>
    </Profile>
    <!-- Active tab underline — MDM green, 2px, anchored to bottom-left of tabBar -->
    <Profile name="mdm_tabUnderline" extends="baseReference" with="anchorBottomLeft">
      <imageColor value="0.0 0.82 0.48 1.0"/>
    </Profile>

    <!-- Section header -->
    <Profile name="mdm_sectionHeader" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="18px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- List header row -->
    <Profile name="mdm_listHeaderRow" extends="emptyPanel" with="anchorTopStretchingX">
      <height value="32px"/>
    </Profile>

    <!-- Column headers -->
    <Profile name="mdm_colHeaderLeft" extends="fs25_textDefault">
      <textSize value="14px"/>
      <textBold value="true"/>
      <textUpperCase value="true"/>
      <textColor value="$preset_colorWhite_50"/>
      <textAlignment value="left"/>
      <size value="170px 32px"/>
    </Profile>
    <Profile name="mdm_colHeaderRight" extends="mdm_colHeaderLeft">
      <textAlignment value="right"/>
    </Profile>

    <!-- SmoothList base -->
    <Profile name="mdm_smoothList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
    </Profile>

    <!-- Commodity item row -->
    <Profile name="mdm_commodityItem" extends="emptyPanel" with="anchorTopStretchingX pivotTopLeft">
      <height value="32px"/>
    </Profile>
    <!-- Crop icon (fill type HUD overlay) -->
    <Profile name="mdm_cropIcon" extends="baseReference" with="anchorMiddleLeft">
      <size value="26px 26px"/>
      <position value="5px 0px"/>
      <imageSliceId value="noSlice"/>
    </Profile>
    <Profile name="mdm_commodityItemBg" extends="baseReference" with="anchorStretchingYStretchingX">
      <imageColor value="$preset_fs25_colorGrey"/>
      <imageSelectedColor value="$preset_fs25_colorMainHighlight"/>
      <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50"/>
    </Profile>

    <!-- Cell text styles -->
    <Profile name="mdm_cellLeft" extends="fs25_textDefault" with="anchorStretchingYLeft">
      <size value="350px 32px"/>
      <position value="10px 0"/>
      <textSize value="15px"/>
      <textAlignment value="left"/>
      <textColor value="$preset_fs25_colorMainLight"/>
      <textSelectedColor value="$preset_fs25_colorMainDark"/>
    </Profile>
    <Profile name="mdm_cellRight" extends="mdm_cellLeft">
      <size value="100px 32px"/>
      <position value="290px 0"/>
      <textAlignment value="right"/>
    </Profile>

    <!-- Detail card -->
    <Profile name="mdm_detailCropName" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="24px"/>
      <textBold value="true"/>
      <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>
    <Profile name="mdm_detailRow" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="16px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowInline" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="14px"/>
      <textColor value="$preset_colorWhite"/>
    </Profile>
    <Profile name="mdm_detailRowSmall" extends="fs25_textDefault" with="anchorTopLeft">
      <textSize value="12px"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <!-- Hints -->
    <Profile name="mdm_graphHint" extends="fs25_textDefault" with="anchorMiddleCenter">
      <textSize value="14px"/>
      <textAlignment value="center"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
    <Profile name="mdm_emptyHint" extends="mdm_graphHint"/>
    <Profile name="mdm_hintText" extends="fs25_textDefault" with="anchorBottomRight">
      <textSize value="14px"/>
      <textAlignment value="right"/>
      <textColor value="$preset_colorWhite_50"/>
    </Profile>
  </GUIProfiles>
</GUI>
