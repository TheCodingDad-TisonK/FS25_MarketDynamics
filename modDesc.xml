<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="106">
    <author>TheCodingDad (tison) &amp; LeGrizzly</author>
    <version>0.1.0.0</version>
    <title>
        <en>Market Dynamics</en>
    </title>
    <description>
        <en>Real-world inspired dynamic crop pricing. Prices fluctuate daily and intraday based on global events, weather, and supply/demand. Includes a futures contract system — lock in prices months in advance and hedge your harvest like a real farmer.</en>
    </description>
    <iconFilename>icon.dds</iconFilename>
    <multiplayer supported="false" />

    <extraSourceFiles>
        <!-- Load order is CRITICAL — do not reorder without reviewing dependencies -->

        <!-- 1. Utilities -->
        <sourceFile filename="src/Logger.lua" />

        <!-- 2. Core Systems -->
        <sourceFile filename="src/MarketEngine.lua" />
        <sourceFile filename="src/WorldEventSystem.lua" />
        <sourceFile filename="src/FuturesMarket.lua" />
        <sourceFile filename="src/MarketSerializer.lua" />
        <sourceFile filename="src/PriceHook.lua" />

        <!-- 3. Events -->
        <sourceFile filename="src/events/DroughtEvent.lua" />
        <sourceFile filename="src/events/BumperHarvestEvent.lua" />
        <sourceFile filename="src/events/TradeDisruptionEvent.lua" />
        <sourceFile filename="src/events/GeopoliticalEvent.lua" />

        <!-- 4. Coordinator (loaded last — depends on all above) -->
        <sourceFile filename="src/MarketDynamics.lua" />
    </extraSourceFiles>

    <l10n filenamePrefix="translations/translation" />
</modDesc>
