<?xml version="1.0" encoding="utf-8" standalone="no" ?>

<GUI name="AFMGuiImplement">
    <GuiElement profile="uiInGameMenuFrame">
        <!-- Static page header -->
        <GuiElement profile="afm_menuHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
              <Bitmap profile="afm_implementMenuHeaderIcon" id="categoryHeaderIcon" />
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_afm_toolOverview"/>
            <RoundCorner profile="afm_moneyBoxBg" id="moneyBoxBg" />
            <BoxLayout profile="afm_moneyBox" id="moneyBox">
                <Text profile="afm_balance" text="$l10n_ui_balance:" />
                <Text profile="afm_money" id="currentBalanceText" />
            </BoxLayout>
        </GuiElement>

        <GuiElement profile="afm_settingsLayout" id="mainBox">
            <GuiElement profile="afmMenuVehicleLeftColumn">
                <BoxLayout profile="afm_vehicleHeaderBox" id="tableHeaderBox" size="780px 104px">
                    <GuiElement profile="afm_vehiclesHeaderTextContainer" size="405px 104px">
                        <Button profile="afm_vehiclesHeaderText" text="$l10n_ui_vehicle" onClick="onClickButtonSortByVehicles" onCreate="onCreateButtonSortByVehicles">
                            <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" name="iconAscending" />
                            <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" name="iconDescending" />
                        </Button>
                    </GuiElement>
                    <GuiElement profile="afm_vehiclesHeaderTextContainer" size="240px 104px">
                        <Button profile="afm_vehiclesHeaderTextMed" text="$l10n_afm_category" onClick="onClickButtonSortByCategory" onCreate="onCreateButtonSortByCategory">
                            <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" name="iconAscending" />
                            <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" name="iconDescending" />
                        </Button>
                    </GuiElement>
                    <GuiElement profile="afm_vehiclesHeaderTextContainer" size="110px 104px">
                        <Button profile="afm_vehiclesHeaderTextEnd" text="$l10n_afm_location" onClick="onClickButtonSortByLocation" onCreate="onCreateButtonSortByLocation">
                            <Bitmap profile="fs25_vehiclesHeaderIconSortAscending" name="iconAscending" />
                            <Bitmap profile="fs25_vehiclesHeaderIconSortDescending" name="iconDescending" />
                        </Button>
                    </GuiElement>
                </BoxLayout>

                <SmoothList profile="afmMenuVehicleList" id="vehicleList" focusChangeTop="nil" focusChangeBottom="nil" selectedWithoutFocus="true" onDoubleClick="onButtonWarpVehicle">
                    <ListItem profile="afmMenuVehicleListItem">
                        <Bitmap name="statusMine" profile="afmMenuVehicleStatusIconMine" />
                        <Bitmap name="statusRunning" profile="afmMenuVehicleStatusIconRunning" />
                        <Bitmap name="statusParked" profile="afmMenuVehicleStatusIconParked" />
                        <RoundCorner profile="afm_multiplayerUsersListItemDotBG" name="dotBg" />
                        <RoundCorner profile="afm_multiplayerUsersListItemDot" name="dot" />
                        <Text name="title" profile="afmMenuVehicleItemTitle" />
                        <Text name="type" profile="afmMenuVehicleItemType" />
                        <Text name="location" profile="afmMenuVehicleItemLocation" />
                    </ListItem>
                </SmoothList>

                <ThreePartBitmap profile="afm_vehicleListSliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="vehicleList" />
                </ThreePartBitmap>

            </GuiElement>

            <GuiElement profile="afmMenuVehicleRightColumn" id="pricesColumn">
                <BoxLayout profile="afm_vehicleHeaderBoxRight" id="tableHeaderBox" size="580px 104px">
                    <Text profile="afm_menuHeader" size="330px 104px" text="$l10n_ui_information" />
                </BoxLayout>
                <Text profile="afmMenuInfoSubheader" id="afmInfoSubVeh" size="330px 50px" text="$l10n_ui_information" />
                <Bitmap name="vehicleIcon" id="vehicleIcon" profile="afm_MenuVehicleIcon" />
                
                <SmoothList profile="afmMenuVehicleDetailList" id="vehicleDetail">
                    <ListItem profile="afmMenuVehicleDetailListItem" name="vehicleDetailItem">
                        <Bitmap profile="afm_MenuVehicleDetailItemIcon" name="itemIcon" visible="false" />
                        <Bitmap profile="afm_MenuVehicleDetailFillIcon" name="fillIcon" visible="false" />
                        <Text profile="afmMenuVehicleDetailTitle" name="detailTitle" />
                        <Text profile="afmMenuVehicleDetailLevel" name="detailLevel" />
                        <ThreePartBitmap profile="afmMenuVehicleDetailBarBackground" name="detailBarBG" >
                            <ThreePartBitmap profile="afmMenuVehicleDetailBar" name="detailBar"/>
                        </ThreePartBitmap>
                    </ListItem>
                </SmoothList>
                
                <ThreePartBitmap profile="afm_vehicleDetailListSliderBox">
                    <Slider profile="fs25_listSlider" dataElementId="vehicleDetail" />
                </ThreePartBitmap>

                <InGameMapPreview profile="afm_vehiclesIngameMap" id="itemDetailsMap" />

                <Bitmap profile="fs25_itemDetailsFruitIcon" id="fruitIconTemplate" visible="false" />
                <BoxLayout profile="afm_vehiclesDetailsInfoBox" id="attributesLayout">
                    <GuiElement profile="afm_itemDetailsFillTypeTemplateBox" name="fillTypesTemplate">
                        <Bitmap profile="fs25_itemDetailsIcon" name="icon" />
                        <GuiElement profile="fs25_itemDetailsIconsLayoutBox">
                            <BoxLayout profile="fs25_itemDetailsIconsLayout" name="iconsLayout" />
                        </GuiElement>
                    </GuiElement>
                </BoxLayout>

            </GuiElement>

        </GuiElement>
        <GuiElement profile="afm_settingsLayout" id="mainBoxEmpty" visible="false">
            <Text name="descText" text="$l10n_afm_noToolsFound" profile="afm_menuNoItems" />
        </GuiElement>
    </GuiElement>
</GUI>
