<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="shopCategories">
    <GuiElement profile="fs25_shopContainer">
        <GuiElement profile="fs25_shopHeaderPanel">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="fs25_menuHeaderIcon" id="categoryHeaderIcon"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText"/>
        </GuiElement>
        <Text profile="ingameMenuNoContentText" text="$l10n_ui_noShopItems" id="noItemsText" position="-5px 105px"/>
        <SmoothList profile="fs25_shopList" id="categoryList" onDoubleClick="onOpenCategory" listSectionHeader="section" startClipperElementName="startClipper">
            <ListItem profile="fs25_shopListItem" name="category">                
                <Bitmap profile="fs25_shopListItemBackground"/>
                <Bitmap profile="fs25_shopListItemImage" name="icon"/>
                <Text profile="fs25_shopListItemTitle" name="title"/>
                <Text profile="fs25_shopListItemCategory" text="$l10n_shop_category"/>
            </ListItem>
            <ListItem profile="fs25_shopListItem" name="categoryEmpty">
                <Bitmap profile="fs25_shopListItemBackgroundEmpty"/>
            </ListItem>
            <ListItem profile="fs25_shopListSection" name="section">
                <Text profile="fs25_shopListSectionTitle" name="title"/>
            </ListItem>
        </SmoothList>
        <Bitmap profile="fs25_startClipper" name="startClipper" position="-2px 0px"/>
    </GuiElement>
    <ThreePartBitmap profile="fs25_sliderDockedBg">
        <ThreePartBitmap profile="fs25_sliderDockedBox">
            <Slider profile="fs25_sliderDocked" dataElementId="categoryList"/>
        </ThreePartBitmap>
    </ThreePartBitmap>
</GUI>
