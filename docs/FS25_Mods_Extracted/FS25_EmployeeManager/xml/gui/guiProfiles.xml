<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUIProfiles>
    <!-- ============================================================ -->
    <!-- Employee Manager: Contracts-style page profiles               -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- Employee Manager: Icons                                       -->
    <!-- ============================================================ -->

    <Profile name="EM_IconMenu" extends="baseReference" with="anchorMiddleCenter">
        <size value="50px 50px" />
        <imageSliceId value="noSlice" />
        <imageFilename value="g_EMIconMenu" />
        <imageColor value="$preset_fs25_colorMainDark" />
    </Profile>

    <Profile name="EM_IconEmployee" extends="baseReference" with="anchorMiddleCenter">
        <size value="50px 50px" />
        <imageSliceId value="noSlice" />
        <imageFilename value="g_EMIconEmployee" />
        <imageColor value="$preset_fs25_colorMainDark" />
    </Profile>

    <Profile name="EM_IconWorkflow" extends="baseReference" with="anchorMiddleCenter">
        <size value="50px 50px" />
        <imageSliceId value="noSlice" />
        <imageFilename value="g_EMIconWorkflow" />
        <imageColor value="$preset_fs25_colorMainDark" />
    </Profile>

    <Profile name="EM_IconField" extends="baseReference" with="anchorMiddleCenter">
        <size value="50px 50px" />
        <imageSliceId value="noSlice" />
        <imageFilename value="g_EMIconField" />
        <imageColor value="$preset_fs25_colorMainDark" />
    </Profile>

    <Profile name="EM_IconVehicle" extends="baseReference" with="anchorMiddleCenter">
        <size value="50px 50px" />
        <imageSliceId value="noSlice" />
        <imageFilename value="g_EMIconVehicle" />
        <imageColor value="$preset_fs25_colorMainDark" />
    </Profile>

    <!-- Filter switcher (NEW / ACTIVE / OWNED tabs) -->
    <Profile name="EM_FilterSwitcher" extends="fs25_subCategorySelector" with="anchorTopLeft"/>

    <!-- Left list -->
    <Profile name="EM_List" extends="emptyPanel" with="anchorStretchingYStretchingX">
        <showHighlights value="true"/>
        <listItemSpacing value="-10px"/>
    </Profile>

    <!-- List item: custom size -->
    <Profile name="EM_ListItem" extends="fs25_subCategoryListItem">
        <height value="100px"/>
    </Profile>

    <!-- List item: avatar (84x84) + title + subtitle -->
    <Profile name="EM_ListItemAvatar" extends="baseReference" with="anchorTopLeft">
        <size value="70px 70px"/>
        <imageSliceId value="noSlice"/>
        <position value="8px -10px"/>
    </Profile>

    <Profile name="EM_ListItemTitle" extends="fs25_subCategoryListItemName">
        <width value="400px"/>
        <position value="100px -25px"/>
    </Profile>

    <Profile name="EM_ListItemSubtitle" extends="fs25_subCategoryListItemName">
        <width value="200px"/>
        <position value="100px -55px"/>
        <textSize value="20px"/>
        <textBold value="false"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- Detail panel: large avatar -->
    <Profile name="EM_DetailAvatar" extends="baseReference" with="anchorTopLeft">
        <size value="140px 140px"/>
        <imageSliceId value="noSlice"/>
    </Profile>

    <!-- Detail panel: typography (follows CC pattern) -->
    <Profile name="EM_DetailTagline" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textColor value="$preset_fs25_colorMainDefault"/>
        <textAlignment value="left"/>
        <textUpperCase value="true"/>
    </Profile>

    <Profile name="EM_DetailTitle" extends="fs25_contractsContractTitle">
        <textSize value="28px"/>
        <textBold value="true"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="EM_DetailSubtitle" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="false"/>
        <textColor value="$preset_fs25_colorMainDefault"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="EM_DetailStatusLeft" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="24px"/>
        <textBold value="false"/>
        <textColor value="$preset_fs25_colorMainDefault"/>
        <textUpperCase value="true"/>
    </Profile>

    <!-- Section headers (h6-style, uppercase) -->
    <Profile name="EM_SectionTitle" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textUpperCase value="true"/>
        <textColor value="$preset_fs25_colorMainDefault"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Detail info rows: label left, value right -->
    <Profile name="EM_RowLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 0.8"/>
        <textAlignment value="left"/>
        <width value="250px"/>
    </Profile>

    <Profile name="EM_RowValue" extends="fs25_textDefault" with="anchorTopRight">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="right"/>
        <width value="250px"/>
    </Profile>

    <!-- Row value: left-aligned (for absolute-positioned 2-column layouts) -->
    <Profile name="EM_RowValue_Left" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="left"/>
        <width value="200px"/>
    </Profile>

    <!-- Skill bars -->
    <Profile name="EM_SkillLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textColor value="1 1 1 0.8"/>
        <textAlignment value="left"/>
        <width value="120px"/>
    </Profile>

    <!-- Still used by EMTrainingDialog -->
    <Profile name="EM_SkillStars" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textColor value="0.95 0.78 0.2 1"/>
        <textAlignment value="left"/>
        <width value="200px"/>
    </Profile>

    <Profile name="EM_SkillXP" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textColor value="1 1 1 0.5"/>
        <textAlignment value="left"/>
        <width value="900px"/>
    </Profile>

    <!-- Footer (wage) -->
    <Profile name="EM_FooterLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textBold value="true"/>
        <textColor value="$preset_colorWhite_50"/>
    </Profile>

    <Profile name="EM_FooterValue" extends="EM_FooterLabel" with="anchorTopRight">
        <textSize value="22px"/>
        <textBold value="true"/>
        <textAlignment value="right"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <!-- Shared / empty state -->
    <Profile name="EM_HeaderLeft" extends="fs25_statisticsHeaderText" with="anchorTopLeft"/>

    <Profile name="EM_EmptyText" extends="fs25_textGrey" with="anchorMiddleCenter">
        <textAlignment value="center"/>
        <textVerticalAlignment value="middle"/>
        <textSize value="24px"/>
    </Profile>

    <!-- Layout helpers -->
    <Profile name="EM_RowBoxH" extends="emptyPanel" with="anchorTopLeft">
        <layoutDirection value="horizontal"/>
        <layoutSpacing value="10px"/>
        <clipChildren value="false"/>
    </Profile>

    <Profile name="EM_ColBoxV" extends="emptyPanel" with="anchorTopLeft">
        <layoutDirection value="vertical"/>
        <layoutSpacing value="4px"/>
        <clipChildren value="false"/>
    </Profile>

    <!-- ============================================================ -->
    <!-- Detail Panel: condensed employee info (right side)           -->
    <!-- ============================================================ -->

    <!-- Large portrait (160x160) -->
    <Profile name="EM_LargePortrait" extends="baseReference" with="anchorTopLeft">
        <size value="160px 160px"/>
        <imageSliceId value="noSlice"/>
    </Profile>

    <!-- Vertical separator between columns -->
    <Profile name="EM_VerticalSeparator" extends="fs25_animalSmallStatusBarBackground" with="anchorTopLeft">
        <size value="2px 600px"/>
        <imageColor value="0.5 0.5 0.5 0.3"/>
        <startImageColor value="0.5 0.5 0.5 0.3"/>
        <endImageColor value="0.5 0.5 0.5 0.3"/>
        <imageFocusedColor value="0.5 0.5 0.5 0.3"/>
        <imageSelectedColor value="0.5 0.5 0.5 0.3"/>
    </Profile>

    <!-- Skill progress bars (adapted from fs25_animalSmallStatusBar) -->
    <Profile name="EM_SkillBarBackground" extends="fs25_animalSmallStatusBarBackground" with="anchorTopLeft">
        <size value="180px 8px"/>
        <imageColor value="0.2 0.2 0.25 0.8"/>
        <startImageColor value="0.2 0.2 0.25 0.8"/>
        <endImageColor value="0.2 0.2 0.25 0.8"/>
        <imageFocusedColor value="0.2 0.2 0.25 0.8"/>
        <imageSelectedColor value="0.2 0.2 0.25 0.8"/>
    </Profile>

    <Profile name="EM_SkillBar" extends="fs25_animalSmallStatusBar" with="anchorTopLeft">
        <size value="180px 8px"/>
        <imageColor value="0.95 0.78 0.2 1"/>
        <startImageColor value="0.95 0.78 0.2 1"/>
        <endImageColor value="0.95 0.78 0.2 1"/>
        <imageFocusedColor value="0.95 0.78 0.2 1"/>
        <imageSelectedColor value="0.95 0.78 0.2 1"/>
    </Profile>

    <!-- Skill level text (right of bar) -->
    <Profile name="EM_SkillLevel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="true"/>
        <textColor value="0.95 0.78 0.2 1"/>
        <textAlignment value="right"/>
        <width value="50px"/>
    </Profile>

    <!-- Trait badge -->
    <Profile name="EM_TraitBadge" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="false"/>
        <textColor value="0.7 0.85 1 1"/>
        <textAlignment value="left"/>
    </Profile>

    <!-- Personal info labels and values -->
    <Profile name="EM_PersonalLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 0.6"/>
        <textAlignment value="left"/>
        <width value="120px"/>
    </Profile>

    <Profile name="EM_PersonalValue" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="16px"/>
        <textBold value="true"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="left"/>
        <width value="200px"/>
    </Profile>

    <!-- Bio/personality text with wrapping -->
    <Profile name="EM_BioText" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="15px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 0.85"/>
        <textAlignment value="left"/>
    <textMaxNumLines value="3" />
    <textWrapWidth value="350px" />
        <width value="350px"/>
        <height value="80px"/>
    </Profile>

    <!-- Quote text (golden italic feel) -->
    <Profile name="EM_QuoteText" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="15px"/>
        <textBold value="false"/>
        <textColor value="0.95 0.78 0.2 0.9"/>
        <textAlignment value="left"/>
    <textMaxNumLines value="3" />
    <textWrapWidth value="350px" />
        <width value="350px"/>
        <height value="80px"/>
    </Profile>

    <!-- ============================================================ -->
    <!-- Legacy profiles: used by EMGui frames (Employee/Field/Vehicle/Workflow) -->
    <!-- ============================================================ -->

    <Profile name="EM_InfoTitle" extends="fs25_contractsContractTitle">
        <textSize value="28px"/>
        <textBold value="true"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
        <textAlignment value="left"/>
    </Profile>

    <Profile name="EM_InfoLabel" extends="fs25_textDefault" with="anchorTopLeft">
        <textSize value="18px"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="left"/>
        <textUpperCase value="true"/>
    </Profile>

    <Profile name="EM_InfoValue" extends="fs25_textDefault" with="anchorTopRight">
        <textSize value="24px"/>
        <textBold value="false"/>
        <textColor value="1 1 1 1"/>
        <textAlignment value="right"/>
        <textUpperCase value="true"/>
    </Profile>

    <Profile name="EM_InfoSelector" extends="fs25_subCategorySelector" with="anchorTopLeft">
        <textSize value="18px"/>
    </Profile>

    <Profile name="EM_TaskListItem" extends="fs25_subCategoryListItem">
        <width value="220px"/>
        <height value="30px"/>
    </Profile>

    <Profile name="EM_SmallButton" extends="buttonActivate" with="anchorTopLeft">
        <size value="36px 30px"/>
        <textSize value="16px"/>
    </Profile>

    <Profile name="emMenuLeftColumn" extends="emptyPanel" with="anchorTopLeft">
        <size value="400px 780px"/>
    </Profile>

    <Profile name="emMenuRightColumn" extends="emptyPanel" with="anchorTopLeft">
        <size value="400px 780px"/>
        <position value="340px 0px"/>
    </Profile>

    <Profile name="emMenuList" extends="emptyPanel" with="anchorTopLeft">
        <showHighlights value="true"/>
        <listItemSpacing value="-20px"/>
    </Profile>

    <Profile name="emMenuListItem" extends="fs25_subCategoryListItem">
        <width value="300px"/>
        <height value="64px"/>
    </Profile>

    <Profile name="emMenuListItemTitle" extends="fs25_subCategoryListItemName">
        <width value="240px"/>
        <position value="44px -16px"/>
    </Profile>

    <Profile name="emMenuListItemSubtitle" extends="fs25_subCategoryListItemName">
        <width value="240px"/>
        <position value="44px -40px"/>
        <textSize value="18px"/>
        <textBold value="false"/>
        <textColor value="$preset_fs25_colorMainHighlight"/>
    </Profile>

    <Profile name="emMenuListSliderBox" extends="fs25_listSliderBox" with="anchorTopRight">
        <position value="-10px -64px"/>
        <height value="680px"/>
    </Profile>

    <!-- ============================================================ -->
    <!-- Workflow Editor profiles (unchanged)                          -->
    <!-- ============================================================ -->

    <Profile name="WE_FullscreenBg" extends="baseReference" with="anchorBottomLeft">
        <size value="100% 100%"/>
        <imageColor value="0.08 0.08 0.12 0.98"/>
        <imageSliceId value="noSlice"/>
    </Profile>

    <Profile name="WE_MainContainer" extends="emptyPanel" with="anchorMiddleCenter">
        <size value="1400px 620px"/>
    </Profile>

    <Profile name="WE_HeaderBar" extends="emptyPanel" with="anchorTopLeft">
        <size value="1400px 50px"/>
    </Profile>

    <Profile name="WE_ContentArea" extends="emptyPanel" with="anchorTopLeft">
        <size value="1400px 460px"/>
    </Profile>

    <Profile name="WE_LeftColumn" extends="emptyPanel" with="anchorTopLeft">
        <size value="540px 460px"/>
    </Profile>

    <Profile name="WE_RightColumn" extends="emptyPanel" with="anchorTopLeft">
        <size value="750px 460px"/>
    </Profile>

    <Profile name="WE_TaskList" extends="emptyPanel" with="anchorTopLeft">
        <showHighlights value="true"/>
        <listItemSpacing value="-20px"/>
    </Profile>

    <Profile name="WE_ButtonBar" extends="emptyPanel" with="anchorBottomCenter">
        <size value="1400px 60px"/>
        <layoutDirection value="horizontal"/>
        <layoutSpacing value="15px"/>
        <layoutAlignment value="center"/>
    </Profile>
</GUIProfiles>
