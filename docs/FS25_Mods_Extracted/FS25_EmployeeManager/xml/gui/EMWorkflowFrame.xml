<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="EMWorkflow">
    <GuiElement profile="uiInGameMenuFrame">
        <GuiElement profile="fs25_menuHeaderPanel" position="-3px 82px" width="800px">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="EM_IconWorkflow" />
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_em_tab_workflows" />
        </GuiElement>

        <!-- Content area: 2-column layout with avatar list + wide panel -->
        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="-200px 0px" debugEnabled="false">
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="500px" height="1200px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow" />

                <!-- Column 1: Hired employees list with avatars (~400px) -->
                <GuiElement profile="fs25_subCategoryContainer" width="400px">
                    <Text profile="EM_SectionTitle" position="50px -80px" size="380px 32px" text="$l10n_em_list_owned"/>

                    <GuiElement profile="fs25_subCategoryListContainer" id="employeesContainer" position="30px -150px" width="400px" height="1000px">
                        <SmoothList id="employeeList" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                            <ListItem profile="EM_ListItem" width="400px">
                                <Bitmap profile="EM_ListItemAvatar" name="avatar"/>
                                <!-- <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/> -->
                                <Text profile="EM_ListItemTitle" name="title" width="100"/>
                                <Text profile="EM_ListItemSubtitle" name="subtitle" width="50"/>
                            </ListItem>
                        </SmoothList>

                        <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                            <Slider profile="fs25_listSlider" dataElementId="employeeList"/>
                        </ThreePartBitmap>
                    </GuiElement>
                </GuiElement>
            </ThreePartBitmap>

            <!-- Column 2: Wide config panel (~900px) -->
            <GuiElement id="mainBox" position="500px 100px" width="900px" height="600px" visible="false" debugEnabled="false">

                <!-- Row 1: Split Config (Left) and Skills (Right) -->

                <!-- COL 1: Selectors (Width ~400px) -->
                <Text profile="EM_SectionTitle" position="0px 0px" text="$l10n_em_employee_info_title" width="400px"/>

                <Text profile="EM_RowLabel" position="0px -40px" text="$l10n_em_field_selector" width="120px"/>
                <MultiTextOption profile="EM_InfoSelector" id="fieldSelector" onClick="onFieldChanged" size="300px 32px" position="130px -30px"/>

                <Text profile="EM_RowLabel" position="0px -90px" text="$l10n_em_assigned_vehicle" width="120px"/>
                <MultiTextOption profile="EM_InfoSelector" id="vehicleSelector" onClick="onVehicleChanged" size="300px 32px" position="130px -80px"/>
                
                <Text profile="EM_RowLabel" position="0px -140px" text="$l10n_em_shift_label" width="120px"/>

                <MultiTextOption profile="EM_InfoSelector" id="shiftStartSelector" onClick="onShiftStartChanged" size="200px 32px" position="130px -130px"/>

                <Text profile="EM_InfoSelector" text="$l10n_em_shift_to" width="30px" position="340px -130px"/>

                <MultiTextOption profile="EM_InfoSelector" id="shiftEndSelector" onClick="onShiftEndChanged" size="200px 32px" position="380px -130px"/>

                <!-- COL 2: Skills (Starting x=450px) -->
                <Text profile="EM_SectionTitle" position="450px 0px" text="$l10n_em_employee_skills_title" width="400px"/>

                <!-- Driving -->
                <Text profile="EM_SkillLabel" position="450px -30px" text="$l10n_em_skill_driving" width="120px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="580px -35px" width="220px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillDriving"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillDrivingLevel" position="810px -30px" width="80px"/>

                <!-- Harvesting -->
                <Text profile="EM_SkillLabel" position="450px -65px" text="$l10n_em_skill_harvesting" width="120px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="580px -70px" width="220px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillHarvesting"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillHarvestingLevel" position="810px -65px" width="80px"/>

                <!-- Technical -->
                <Text profile="EM_SkillLabel" position="450px -100px" text="$l10n_em_skill_technical" width="120px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="580px -105px" width="220px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillTechnical"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillTechnicalLevel" position="810px -100px" width="80px"/>

                <!-- Separator: Row 1 -> Row 2 -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -180px" width="900px"/>

                <!-- Row 2: Workflow Builder (Full Width) -->
                <Text profile="EM_SectionTitle" position="0px -200px" text="$l10n_em_workflow_builder"/>

                <Text profile="EM_RowLabel" position="50px -230px" text="$l10n_em_available_tasks" width="250px"/>
                <Text profile="EM_RowLabel" position="450px -230px" text="$l10n_em_workflow_queue" width="250px"/>

                <!-- List: Available -->
                <GuiElement profile="fs25_subCategoryListContainer" id="availableTasksContainer" position="50px -260px" width="300px" height="400px">
                    <SmoothList id="availableTasksList" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                        <ListItem profile="EM_ListItem" width="300px" height="110px">
                            <!-- <Bitmap profile="EM_ListItemAvatar" name="avatar"/> -->
                            <!-- <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/> -->
                            <Text profile="EM_ListItemTitle" name="title" textSize="18px"/>
                        </ListItem>
                    </SmoothList>

                    <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                        <Slider profile="fs25_listSlider" dataElementId="availableTasksList"/>
                    </ThreePartBitmap>
                </GuiElement>

                <!-- Buttons: Add/Remove (Centered between lists) -->
                <BoxLayout profile="EM_ColBoxV" position="370px -690px" width="60px">
                    <Button profile="buttonActivate" text="&lt;&lt;" onClick="onTaskRemove">
                        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
                    </Button>
                </BoxLayout>

                <BoxLayout profile="EM_ColBoxV" position="500px -690px" width="60px">
                    <Button profile="buttonActivate" text="&gt;&gt;" onClick="onTaskAdd">
                        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
                    </Button>
                </BoxLayout>

                <!-- List: Queue -->
                <GuiElement profile="fs25_subCategoryListContainer" id="queueTasksContainer" position="450px -260px" width="300px" height="400px">
                    <SmoothList id="queueList" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                        <ListItem profile="EM_ListItem" height="100px" width="300px">
                            <!-- <Bitmap profile="EM_ListItemAvatar" name="avatar"/> -->
                            <!-- <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/> -->
                            <Text profile="EM_ListItemTitle" name="title" width="100" textSize="18px"/>
                        </ListItem>
                    </SmoothList>

                    <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                        <Slider profile="fs25_listSlider" dataElementId="queueList"/>
                    </ThreePartBitmap>
                </GuiElement>

                <!-- Buttons: Up/Down (Right of queue) -->
                <BoxLayout profile="EM_ColBoxV" position="770px -690px" width="60px">
                    <Button profile="buttonActivate" text="^" onClick="onTaskUp">
                        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
                    </Button>
                </BoxLayout>

                <BoxLayout profile="EM_ColBoxV" position="900px -690px" width="60px">
                    <Button profile="buttonActivate" text="v" onClick="onTaskDown">
                        <Bitmap profile="fs25_dialogButtonBoxSeparator"/>
                    </Button>
                </BoxLayout>

                <Text profile="EM_SkillXP" id="txtStatusMessage" position="0px -730px"/>
            </GuiElement>
        </GuiElement>

        <Text profile="EM_EmptyText" id="emptyText" text="$l10n_em_error_no_hired" visible="false" />
    </GuiElement>
</GUI>
