<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="menuEmployeeManager">
    <GuiElement profile="fs25_menuContainer">
        <!-- Header bar with title + money -->
        <!-- position parameters 1 2
            1: vertical offset from center (negative = down, positive = up)
            2: horizontal offset from center (negative = left, positive = right)
        -->
        <!-- position="0px 50px" width="800px" -->
        <GuiElement profile="fs25_menuHeaderPanel" position="-50px 90px" width="800px">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="EM_IconMenu"/>
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" id="categoryHeaderText"/>

            <RoundCorner profile="fs25_shopMoneyBoxBg" id="shopMoneyBoxBg" position="380px 0px"/>
            <BoxLayout profile="fs25_shopMoneyBox" id="shopMoneyBox" position="350px 0px">
                <Text profile="fs25_shopBalance" text="$l10n_em_current_balance"/>
                <Text profile="fs25_shopMoney" id="currentBalanceText"/>
            </BoxLayout>
        </GuiElement>

        <!-- Content area: native subCategory pattern -->
        <!-- position="-150px 0px" height="800px" width="" -->
        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="-180px 0px" debugEnabled="false">
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="500px" height="1200px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow" />

                <!-- Left column: wide employee list (~400px) -->
                <GuiElement profile="fs25_subCategoryContainer" width="400px">
                    <MultiTextOption profile="EM_FilterSwitcher" id="pageSwitcher" onClick="onSwitchPage" size="380px 32px" position="50px -30px"/>

                    <!-- position="0px -100px" width="400px" height="" -->
                    <GuiElement profile="fs25_subCategoryListContainer" id="employeesContainer" position="30px -100px" width="400px" height="1000px">
                        <!-- <Bitmap profile="fs25_subCategoryStartClipper" name="startClipper"/> -->
                        <!-- <Bitmap profile="fs25_subCategoryStopClipper" name="endClipper"/> -->

                        <SmoothList id="leftListTable" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                            <ListItem profile="EM_ListItem" width="400px">
                                <Bitmap profile="EM_ListItemAvatar" name="avatar"/>
                                <Bitmap profile="fs25_subCategoryListItemIcon" name="icon" />
                                <Text profile="EM_ListItemTitle" name="title" width="100" />
                                <Text profile="EM_ListItemSubtitle" name="subtitle" width="50" />
                                <!-- <Text profile="EM_RowValue" name="price" position="300px -25px"/> -->
                            </ListItem>
                        </SmoothList>

                        <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                            <Slider profile="fs25_listSlider" dataElementId="leftListTable"/>
                        </ThreePartBitmap>
                    </GuiElement>
                </GuiElement>
            </ThreePartBitmap>

            <!-- Empty state: no items -->
            <GuiElement id="noEmployeesContainer">
                <Text profile="EM_HeaderLeft" text="$l10n_em_employee_empty" position="0px -150px" width="600px"/>
                <ThreePartBitmap profile="fs25_contractsContentSeparator"/>
            </GuiElement>

            <!-- Empty state: no selection -->
            <Text id="noSelectedText" profile="EM_HeaderLeft" text="$l10n_em_employee_empty" position="700px -230px" width="400px" visible="false"/>

            <!-- Column 2: Employee professional card (~400px) -->
            <GuiElement id="detailPanelContainer" position="500px 100px" width="500px" height="600px" visible="false" debugEnabled="false">

                <!-- Portrait + Identity (top area) -->
                <Bitmap profile="EM_LargePortrait" id="detailAvatar" position="0px -20px"/>

                <Text profile="EM_DetailTagline" id="employeeId" position="175px -20px"/>
                <Text profile="EM_DetailTitle" id="employeeName" position="175px -40px" />
                <!-- <Text profile="EM_DetailSubtitle" id="employeeTrait" position="175px -80px" /> -->
                <Text profile="EM_DetailStatusLeft" id="employeeStatusValue" position="175px -110px"/>

                <!-- Separator: Identity → Skills -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -200px" width="400px"/>

                <!-- Skills section with progress bars -->
                <Text profile="EM_SectionTitle" position="0px -235px" text="$l10n_em_employee_skills_title"/>

                <!-- Driving -->
                <Text profile="EM_SkillLabel" position="0px -270px" text="$l10n_em_skill_driving" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -278px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillDriving"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillDrivingLevel" position="400px -270px" width="100px"/>

                <!-- Harvesting -->
                <Text profile="EM_SkillLabel" position="0px -298px" text="$l10n_em_skill_harvesting" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -306px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillHarvesting"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillHarvestingLevel" position="400px -298px" width="100px"/>

                <!-- Technical -->
                <Text profile="EM_SkillLabel" position="0px -326px" text="$l10n_em_skill_technical" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -334px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillTechnical"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillTechnicalLevel" position="400px -326px" width="100px"/>

                <!-- Separator: Skills → Traits -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -375px" width="400px"/>

                <!-- Traits -->
                <GuiElement id="traitsSection" position="0px -410px" debugEnabled="false">
                    <Text profile="EM_SectionTitle" position="0px 0px" text="$l10n_em_label_traits"/>
                    <Text profile="EM_TraitBadge" id="txtTraitsList" position="0px -25px" />
                </GuiElement>

                <!-- Separator: Traits → Wage -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -510px" width="400px"/>

                <!-- Wage -->
                <Text profile="EM_FooterLabel" position="0px -545px" text="$l10n_em_employee_total_wage"/>
                <Text profile="EM_FooterValue" position="0px -545px" id="employeeWageValue" width="400px"/>
            </GuiElement>

            <!-- Vertical separator: Column 2 | Column 3 -->
            <Bitmap profile="fs25_settingsTooltipSeparator" name="separator" position="1020px 0px" />

            <!-- Column 3: Personal info, biography, description (~400px) -->
            <GuiElement id="personalPanelContainer" position="1040px 100px" width="500px" height="600px" visible="false" debugEnabled="false">

                <!-- Personal info: Age + Nationality -->
                <Text profile="EM_SectionTitle" position="0px -20px" text="$l10n_em_personal_info_title"/>

                <!-- Spacing adjusted: EM_SectionTitle -> EM_ColBoxV = 25px -->
                <BoxLayout profile="EM_ColBoxV" position="0px -45px" width="500px">
                    <BoxLayout profile="EM_RowBoxH" width="500px">
                        <Text profile="EM_RowLabel" text="$l10n_em_personal_age" width="250px"/>
                        <Text profile="EM_RowValue" id="txtPersonalAge" width="250px"/>
                    </BoxLayout>
                </BoxLayout>

                <BoxLayout profile="EM_ColBoxV" position="0px -80px" width="500px">
                    <BoxLayout profile="EM_RowBoxH" width="500px">
                        <Text profile="EM_RowLabel" text="$l10n_em_personal_nationality" width="250px"/>
                        <Text profile="EM_RowValue" id="txtPersonalNationality" width="250px"/>
                    </BoxLayout>
                </BoxLayout>

                <!-- Separator: Personal Info → Biography -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -115px" width="500px"/>

                <!-- Biography (positions normalized) -->
                <!-- Spacing adjusted so separator -> biography box = 35px -->
                <Text profile="EM_SectionTitle" position="0px -150px" text="$l10n_em_personal_bio"/>
                <Text profile="EM_BioText" id="txtPersonalBio" position="0px -175px" width="500px"/>

                <!-- Separator: Biography → Quote -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -270px" width="500px"/>

                <!-- Quote / Description (positions normalized) -->
                <!-- Spacing adjusted so separator -> quote box = 35px -->
                <Text profile="EM_SectionTitle" position="0px -305px" text="$l10n_em_personal_quote"/>
                <Text profile="EM_QuoteText" id="txtPersonalQuote" position="0px -330px" width="500px"/>

                <!-- Separator: Quote → Work Stats -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -400px" width="500px"/>

                <!-- Work stats (visible only for hired employees) -->
                <!-- Spacing adjusted so separator -> workStats = 35px -->
                <GuiElement id="workStatsSection" position="0px -435px" width="500px" visible="false">
                    <Text profile="EM_SectionTitle" position="0px 0px" text="$l10n_em_employee_info_title"/>

                    <!-- EM_SectionTitle -> EM_ColBoxV = 25px -->
                    <BoxLayout profile="EM_ColBoxV" position="0px -25px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_current_job" width="250px"/>
                            <Text profile="EM_RowValue" id="statCurrentJob" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <BoxLayout profile="EM_ColBoxV" position="0px -48px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_assigned_field" width="250px"/>
                            <Text profile="EM_RowValue" id="txtAssignedField" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <BoxLayout profile="EM_ColBoxV" position="0px -72px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_hours_worked" width="250px"/>
                            <Text profile="EM_RowValue" id="statHoursWorked" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <BoxLayout profile="EM_ColBoxV" position="0px -96px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_fatigue" width="250px"/>
                            <Text profile="EM_RowValue" id="statFatigue" width="250px"/>
                        </BoxLayout>
                    </BoxLayout>
                </GuiElement>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
