<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="EMEmployee">
    <GuiElement profile="uiInGameMenuFrame">
        <GuiElement profile="fs25_menuHeaderPanel" position="-3px 82px" width="800px">
            <Bitmap profile="fs25_menuHeaderIconBg">
                <Bitmap profile="EM_IconEmployee" />
            </Bitmap>
            <Text profile="fs25_menuHeaderTitle" text="$l10n_em_tab_employees" />
        </GuiElement>

        <!-- Content area: 3-column layout (matches MenuEmployeeManager pattern) -->
        <GuiElement profile="fs25_subCategorySelectorTabbedContainer" position="-200px 0px" debugEnabled="false">
            <ThreePartBitmap profile="fs25_primaryMenuContainerBg" width="500px" height="1200px" position="0px 20px">
                <Bitmap profile="fs25_menuContainerArrow" />

                <!-- Column 1: Employee list with avatars (~400px) -->
                <GuiElement profile="fs25_subCategoryContainer" width="400px">
                    <MultiTextOption profile="EM_FilterSwitcher" id="listSwitcher" onClick="onSwitchList" size="380px 32px" position="50px -80px"/>

                    <GuiElement profile="fs25_subCategoryListContainer" id="employeesContainer" position="30px -150px" width="400px" height="1000px">
                        <SmoothList id="employeeList" profile="EM_List" startClipperElementName="startClipper" endClipperElementName="endClipper">
                            <ListItem profile="EM_ListItem" width="400px">
                                <Bitmap profile="EM_ListItemAvatar" name="avatar"/>
                                <Bitmap profile="fs25_subCategoryListItemIcon" name="icon"/>
                                <Text profile="EM_ListItemTitle" name="title" width="100"/>
                                <Text profile="EM_ListItemSubtitle" name="subtitle" width="50"/>
                            </ListItem>
                        </SmoothList>

                        <ThreePartBitmap profile="fs25_subCategoryListSliderBox">
                            <Slider profile="fs25_listSlider" dataElementId="employeeList"/>
                        </ThreePartBitmap>
                    </GuiElement>

                    <Text profile="EM_RowLabel" id="txtPoolRefresh" position="50px -720px" visible="false"/>
                </GuiElement>
            </ThreePartBitmap>

            <!-- Empty state: no items -->
            <GuiElement id="noEmployeesContainer">
                <Text profile="EM_HeaderLeft" text="$l10n_em_employee_empty" position="0px -150px" width="600px"/>
                <ThreePartBitmap profile="fs25_contractsContentSeparator"/>
            </GuiElement>

            <!-- Empty state: no selection -->
            <Text id="noSelectedText" profile="EM_HeaderLeft" text="$l10n_em_employee_empty" position="700px -230px" width="400px" visible="false"/>

            <!-- Column 2: Professional card (~450px) -->
            <GuiElement id="detailPanel" position="500px 100px" width="500px" height="600px" visible="false" debugEnabled="false">

                <!-- Portrait + Identity -->
                <Bitmap profile="EM_LargePortrait" id="detailAvatar" position="0px -20px"/>

                <Text profile="EM_DetailTagline" id="txtId" position="175px -20px"/>
                <Text profile="EM_DetailTitle" id="txtName" position="175px -40px"/>
                <Text profile="EM_DetailStatusLeft" id="txtStatus" position="175px -110px"/>

                <!-- Separator: Identity -> Skills -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -200px" width="400px"/>

                <!-- Skills section with progress bars -->
                <Text profile="EM_SectionTitle" position="0px -235px" text="$l10n_em_employee_skills_title"/>

                <!-- Driving -->
                <Text profile="EM_SkillLabel" position="0px -270px" text="$l10n_em_skill_driving" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -278px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillDriving"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillDrivingLevel" position="400px -270px" width="100px"/>

                <!-- Harvesting -->
                <Text profile="EM_SkillLabel" position="0px -298px" text="$l10n_em_skill_harvesting" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -306px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillHarvesting"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillHarvestingLevel" position="400px -298px" width="100px"/>

                <!-- Technical -->
                <Text profile="EM_SkillLabel" position="0px -326px" text="$l10n_em_skill_technical" width="150px"/>
                <ThreePartBitmap profile="EM_SkillBarBackground" position="150px -334px" width="250px">
                    <ThreePartBitmap profile="EM_SkillBar" id="barSkillTechnical"/>
                </ThreePartBitmap>
                <Text profile="EM_SkillLevel" id="txtSkillTechnicalLevel" position="400px -326px" width="100px"/>

                <!-- Separator: Skills -> Traits -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -375px" width="400px"/>

                <!-- Traits -->
                <GuiElement id="traitsSection" position="0px -410px" debugEnabled="false">
                    <Text profile="EM_SectionTitle" position="0px 0px" text="$l10n_em_label_traits"/>
                    <Text profile="EM_TraitBadge" id="txtTraitsList" position="0px -25px"/>
                </GuiElement>

                <!-- Separator: Traits -> Wage -->
                <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -510px" width="400px"/>

                <!-- Wage -->
                <Text profile="EM_FooterLabel" position="0px -545px" text="$l10n_em_employee_total_wage"/>
                <Text profile="EM_FooterValue" position="0px -545px" id="txtWage" width="400px"/>
                <Text profile="EM_RowLabel" id="txtWageBreakdown" position="0px -568px" width="400px"/>
            </GuiElement>

            <!-- Vertical separator: Column 2 | Column 3 -->
            <Bitmap profile="fs25_settingsTooltipSeparator" id="columnSeparator" position="1020px 0px"/>

            <!-- Column 3: Context panel (~400px) -->
            <GuiElement id="rightPanel" position="1040px 100px" width="500px" height="600px" visible="false">

                <!-- === HIRED: Work Stats + Performance + Workflow === -->
                <GuiElement id="hiredInfoSection" visible="false">

                    <!-- Work Stats -->
                    <Text profile="EM_SectionTitle" position="0px -20px" text="$l10n_em_employee_stats_title"/>

                    <BoxLayout profile="EM_ColBoxV" position="0px -44px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_hours_worked" width="170px"/>
                            <Text profile="EM_RowValue" id="statHoursWorked" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_km_driven" width="170px"/>
                            <Text profile="EM_RowValue" id="statKmDriven" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_current_job" width="170px"/>
                            <Text profile="EM_RowValue" id="statCurrentJob" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_fatigue" width="170px"/>
                            <Text profile="EM_RowValue" id="statFatigue" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_shift_label" width="170px"/>
                            <Text profile="EM_RowValue" id="statShift" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_parking" width="170px"/>
                            <Text profile="EM_RowValue" id="statParking" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_pending_wages" width="170px"/>
                            <Text profile="EM_RowValue" id="statPendingWages" width="320px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <Text profile="EM_RowLabel" id="statFatigueStatus" position="0px -250px" visible="false"/>
                    <Text profile="EM_RowLabel" id="txtUnpaidWarning" position="0px -270px" visible="false"/>

                    <!-- Separator: Work Stats -> Performance -->
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -250px" width="500px"/>

                    <Text profile="EM_SectionTitle" position="0px -285px" text="$l10n_em_performance_title"/>

                    <BoxLayout profile="EM_ColBoxV" position="0px -310px" width="500px">
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_total_wages" width="170px"/>
                            <Text profile="EM_RowValue" id="statTotalWages" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_tasks_completed" width="170px"/>
                            <Text profile="EM_RowValue" id="statTasksCompleted" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_avg_wage" width="170px"/>
                            <Text profile="EM_RowValue" id="statAvgWage" width="320px"/>
                        </BoxLayout>
                        <BoxLayout profile="EM_RowBoxH" width="500px">
                            <Text profile="EM_RowLabel" text="$l10n_em_stat_efficiency" width="170px"/>
                            <Text profile="EM_RowValue" id="statEfficiency" width="320px"/>
                        </BoxLayout>
                    </BoxLayout>

                    <!-- Separator: Performance -> Workflow -->
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -425px" width="500px"/>

                    <Text profile="EM_SectionTitle" position="0px -460px" text="$l10n_em_workflow_builder"/>
                    <Text profile="EM_RowLabel" id="txtWorkflowSummary" position="0px -485px" width="500px"/>
                </GuiElement>

                <!-- === AVAILABLE: Personal Info + Bio + Quote === -->
                <GuiElement id="availableInfoSection" visible="false">

                    <!-- Personal info: Age + Nationality -->
                    <Text profile="EM_SectionTitle" position="0px -20px" text="$l10n_em_personal_info_title"/>

                    <BoxLayout profile="EM_ColBoxV" position="0px -44px" width="400px">
                        <BoxLayout profile="EM_RowBoxH" width="400px">
                            <Text profile="EM_PersonalLabel" text="$l10n_em_personal_age"/>
                            <Text profile="EM_PersonalValue" id="txtPersonalAge"/>
                        </BoxLayout>
                    </BoxLayout>

                    <BoxLayout profile="EM_ColBoxV" position="0px -74px" width="400px">
                        <BoxLayout profile="EM_RowBoxH" width="400px">
                            <Text profile="EM_PersonalLabel" text="$l10n_em_personal_nationality"/>
                            <Text profile="EM_PersonalValue" id="txtPersonalNationality"/>
                        </BoxLayout>
                    </BoxLayout>

                    <!-- Separator: Personal Info -> Biography -->
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -140px" width="400px"/>

                    <!-- Biography -->
                    <Text profile="EM_SectionTitle" position="0px -175px" text="$l10n_em_personal_bio"/>
                    <Text profile="EM_BioText" id="txtPersonalBio" position="0px -200px" width="400px"/>

                    <!-- Separator: Biography -> Quote -->
                    <ThreePartBitmap profile="fs25_lineSeparatorTop" position="0px -280px" width="400px"/>

                    <!-- Quote -->
                    <Text profile="EM_SectionTitle" position="0px -315px" text="$l10n_em_personal_quote"/>
                    <Text profile="EM_QuoteText" id="txtPersonalQuote" position="0px -340px" width="400px"/>
                </GuiElement>
            </GuiElement>

        </GuiElement>

        <Text profile="EM_EmptyText" id="emptyText" text="$l10n_em_employee_empty" visible="false" />
    </GuiElement>
</GUI>
