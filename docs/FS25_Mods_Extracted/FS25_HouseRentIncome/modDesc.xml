<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<modDesc descVersion="97">
    <title>
        <en>Rent Income Manager</en>
    </title>
    
    <description>
        <en>Manage rental properties and collect daily income. Add houses, set custom rent amounts, and receive automatic payments. Press SHIFT+; to open menu.</en>
    </description>
    
    <author>Zyzex</author>
    <version>1.1</version>
    
    <iconFilename>rent.dds</iconFilename>
    
    <!-- Main script -->
    <extraSourceFiles>
        <sourceFile filename="scripts/RentIncome.lua"/>
    </extraSourceFiles>
    
    <!-- Actions -->
    <actions>
        <action name="RENT_INCOME_MENU" category="ONFOOT" />
        <action name="RENT_INCOME_TOGGLE" category="ONFOOT" />
    </actions>
    
    <!-- Input bindings -->
    <inputBinding>
        <actionBinding action="RENT_INCOME_MENU">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lshift KEY_semicolon" />
        </actionBinding>
        <actionBinding action="RENT_INCOME_TOGGLE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_lctrl KEY_lshift KEY_semicolon" />
        </actionBinding>
    </inputBinding>
    
    <!-- Multiplayer support -->
    <multiplayer supported="true"/>
    
</modDesc>